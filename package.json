{
  "name": "clive-website",
  "type": "module",
  "version": "0.1.0",
  "description": "Clive — Hive blockchain CLI/TUI wallet. Official website and blog.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name=clive-website",
    "deploy:preview": "pnpm build && wrangler pages deploy dist --project-name=clive-website --branch=preview",
    "deploy:vercel": "vercel --prod",
    "deploy:vercel:preview": "vercel"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.7.10",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.0.0"
  }
}
