---
interface Props {
  title?: string;
  ariaLabel?: string;
  class?: string;
  /**
   * Element used for the body wrapper.
   * - `pre` (default): preserves whitespace — for ASCII/inline terminal content.
   * - `div`: flow content — for structured TUI panels with HTML elements.
   */
  as?: "pre" | "div";
}

const {
  title = "clive",
  ariaLabel = "Terminal preview",
  class: className,
  as = "pre",
} = Astro.props;

const BodyTag = as;
---

<figure class:list={["terminal", className]} role="figure" aria-label={ariaLabel}>
  <header class="terminal__bar">
    <span class="terminal__dots" aria-hidden="true">
      <span class="dot dot--red"></span>
      <span class="dot dot--amber"></span>
      <span class="dot dot--green"></span>
    </span>
    <span class="terminal__title">{title}</span>
    <span aria-hidden="true"></span>
  </header>
  <BodyTag class="terminal__body" data-as={as} tabindex="0"><slot /></BodyTag>
</figure>

<style>
  .terminal {
    margin: 0;
    max-width: 100%;
    background-color: var(--mode-bg, var(--color-bg-surface));
    border: 1px solid var(--mode-border, var(--color-border-bright));
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition:
      background-color var(--mode-transition, 300ms) ease,
      border-color var(--mode-transition, 300ms) ease,
      box-shadow var(--mode-transition, 300ms) ease;
  }

  .terminal__bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    height: 36px;
    padding: 0 var(--space-4);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    transition:
      background-color var(--mode-transition, 300ms) ease,
      border-color var(--mode-transition, 300ms) ease;
  }

  .terminal__dots {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
    opacity: 0.6;
  }
  .dot--red {
    background-color: #ff5f57;
  }
  .dot--amber {
    background-color: #febc2e;
  }
  .dot--green {
    background-color: #28c840;
  }

  .terminal__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-align: center;
    letter-spacing: var(--tracking-wide);
  }

  .terminal__body {
    margin: var(--space-2);
    padding: var(--space-3) var(--space-3);
    font-family:
      ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", "JetBrains Mono Variable",
      monospace;
    font-size: clamp(0.6875rem, 0.55rem + 0.5vw, 0.875rem);
    line-height: 1.2;
    color: var(--color-text);
    overflow-x: auto;
    white-space: pre;
    background-color: var(--mode-bg-elevated, var(--color-bg-elevated));
    border: 1px solid var(--mode-border, var(--color-border-default));
    border-radius: var(--radius-md);
    transition:
      background-color var(--mode-transition, 300ms) ease,
      border-color var(--mode-transition, 300ms) ease;
    font-feature-settings:
      "calt" 0,
      "liga" 0;
    font-variant-ligatures: none;
    font-variant-numeric: tabular-nums;
  }
  @media (min-width: 40rem) {
    .terminal__body {
      margin: var(--space-3);
      padding: var(--space-4) var(--space-5);
    }
  }

  .terminal__body:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus-ring);
  }

  /* Structured-content variant: flow children as normal HTML
     (used for TUI panels built with CSS borders, not ASCII art). */
  .terminal__body[data-as="div"] {
    white-space: normal;
    overflow-x: visible;
  }
</style>
