---
type Glow = "none" | "blue" | "cyan" | "green" | "crimson" | "amber" | "hive" | "emerald" | "indigo";

interface Props {
  glow?: Glow;
  fade?: boolean;
  as?: "article" | "div" | "section";
  class?: string;
}

const props: Props = Astro.props;
const {
  glow = "none",
  fade = false,
  as: Tag = "article",
  class: className,
} = props;
---

<Tag class:list={["card", `card--glow-${glow}`, className]}>
  {glow !== "none" && <div class="card__glow" aria-hidden="true" />}
  <div class="card__inner">
    <slot />
  </div>
  {fade && <div class="card__fade" aria-hidden="true" />}
</Tag>

<style>
  .card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background-color: var(--color-bg-elevated);
    /* TUI panel-style: 1px electric blue border at 40% opacity, 100% on hover */
    border: 1px solid color-mix(in srgb, var(--color-border-bright) 40%, transparent);
    border-radius: var(--radius-lg);
    transition:
      transform var(--duration-base) var(--ease-out-quint),
      border-color 200ms var(--ease-out-quad),
      box-shadow var(--duration-base) var(--ease-out-quint);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-bright);
    box-shadow: var(--shadow-md);
  }
  .card:focus-within {
    box-shadow: var(--shadow-focus-ring);
  }

  /* Hive brand-anchor variant: red border instead of blue */
  .card--glow-hive {
    border-color: color-mix(in srgb, var(--color-hive) 50%, transparent);
  }
  .card--glow-hive:hover {
    border-color: var(--color-hive);
  }

  .card__inner {
    position: relative;
    z-index: 1;
    padding: var(--space-6);
  }
  @media (min-width: 48rem) {
    .card__inner {
      padding: var(--space-8);
    }
  }

  .card__glow {
    position: absolute;
    inset: -20% -20% auto -20%;
    height: 60%;
    z-index: 0;
    pointer-events: none;
    filter: blur(48px);
    opacity: 0.7;
    transition: opacity var(--duration-base) var(--ease-out-quad);
  }
  .card:hover .card__glow {
    opacity: 1;
  }
  .card--glow-blue .card__glow,
  .card--glow-indigo .card__glow {
    background: var(--tint-blue);
  }
  .card--glow-cyan .card__glow {
    background: var(--tint-cyan);
  }
  .card--glow-green .card__glow,
  .card--glow-emerald .card__glow {
    background: var(--tint-green);
  }
  .card--glow-crimson .card__glow {
    background: var(--tint-crimson);
  }
  .card--glow-amber .card__glow {
    background: var(--tint-amber);
  }
  .card--glow-hive .card__glow {
    background: var(--tint-hive);
  }

  .card__fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 35%;
    background: var(--gradient-card-fade);
    pointer-events: none;
    z-index: 0;
  }
</style>
