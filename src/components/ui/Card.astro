---
type Glow = "none" | "blue" | "cyan" | "green" | "crimson" | "amber" | "hive" | "emerald" | "indigo";

interface Props {
  title?: string;
  glow?: Glow;
  as?: "article" | "div" | "section";
  class?: string;
}

const props: Props = Astro.props;
const {
  title,
  glow = "none",
  as: Tag = "article",
  class: className,
} = props;
---

<Tag
  class:list={["card", "card--tui", `card--glow-${glow}`, className]}
  data-has-title={title ? "true" : "false"}
>
  {title && <span class="card__titlebar" aria-hidden="true">{title}</span>}
  <div class="card__inner">
    <slot />
  </div>
</Tag>

<style>
  .card {
    position: relative;
    background-color: var(--color-bg-surface);
    border: var(--tui-border-dim);
    border-radius: var(--tui-radius);
    transition:
      background-color var(--duration-base) var(--ease-out-quad),
      border-color var(--duration-base) var(--ease-out-quad),
      transform var(--duration-fast) var(--ease-out-quad);
  }
  .card:hover {
    background-color: var(--color-bg-elevated);
    border-color: var(--color-border-bright);
    transform: translateY(-1px);
  }
  .card:focus-within {
    border-color: var(--color-border-bright);
    box-shadow: var(--shadow-focus-ring);
  }

  .card[data-has-title="true"] .card__titlebar {
    position: absolute;
    top: -0.55em;
    left: var(--space-4);
    padding: 0 var(--space-2);
    background-color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
    white-space: nowrap;
    z-index: 1;
  }
  .card[data-has-title="true"] .card__titlebar::before {
    content: "╭─ ";
    color: var(--color-border-bright);
  }
  .card[data-has-title="true"] .card__titlebar::after {
    content: " ─╮";
    color: var(--color-border-bright);
  }

  /* Hive brand-anchor variant: red border instead of blue */
  .card--glow-hive {
    border-color: color-mix(in srgb, var(--color-hive) 50%, transparent);
  }
  .card--glow-hive:hover {
    border-color: var(--color-hive);
  }
  .card--glow-hive .card__titlebar::before,
  .card--glow-hive .card__titlebar::after {
    color: var(--color-hive);
  }

  .card__inner {
    padding: var(--space-6);
  }
  @media (min-width: 48rem) {
    .card__inner {
      padding: var(--space-8) var(--space-7);
    }
  }
</style>
