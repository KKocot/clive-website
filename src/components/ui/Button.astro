---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "secondary" | "ghost";
type Size = "sm" | "md" | "lg";

interface Props extends Omit<HTMLAttributes<"a">, "size"> {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type,
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? "a" : "button";

const baseClass =
  "btn inline-flex items-center justify-center gap-2 font-medium select-none whitespace-nowrap";
const sizeClass: Record<Size, string> = {
  sm: "btn--sm h-8 px-3 text-sm",
  md: "btn--md h-10 px-4 text-base",
  lg: "btn--lg h-12 px-6 text-base",
};
const variantClass: Record<Variant, string> = {
  primary: "btn--primary",
  secondary: "btn--secondary",
  ghost: "btn--ghost",
};
---

<Tag
  href={href}
  type={!href ? (type ?? "button") : undefined}
  class:list={[baseClass, sizeClass[size], variantClass[variant], className]}
  {...rest}
>
  <slot />
  <slot name="icon-end" />
</Tag>

<style>
  .btn {
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: var(--tui-radius);
    transition:
      background-color var(--duration-fast) var(--ease-out-quad),
      border-color var(--duration-fast) var(--ease-out-quad),
      box-shadow var(--duration-fast) var(--ease-out-quad),
      transform var(--duration-fast) var(--ease-out-quad),
      color var(--duration-fast) var(--ease-out-quad);
  }
  .btn:focus-visible {
    box-shadow: var(--shadow-focus-ring);
    outline: none;
  }
  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Primary — electric blue (no glow) */
  .btn--primary {
    background-color: var(--color-primary);
    color: #ffffff;
    border-color: transparent;
  }
  .btn--primary:hover {
    background-color: var(--color-primary-bright);
    color: #0b1224;
    text-shadow: var(--glow-intensity) var(--glow-color);
  }
  .btn--primary:active {
    background-color: var(--color-accent-primary-active);
    color: #ffffff;
    transform: translateY(1px);
  }

  /* Secondary — bright blue outline */
  .btn--secondary {
    background-color: transparent;
    color: var(--color-primary-bright);
    border-color: var(--color-border-bright);
  }
  .btn--secondary:hover {
    background-color: rgba(1, 120, 212, 0.10);
    color: var(--color-primary-bright);
    border-color: var(--color-primary-bright);
    text-shadow: var(--glow-intensity) var(--glow-color);
  }
  .btn--secondary:active {
    background-color: rgba(1, 120, 212, 0.18);
    transform: translateY(1px);
  }

  /* Ghost — bracket-decorated mono */
  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary-bright);
    border-color: transparent;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .btn--ghost::before {
    content: "[ ";
    color: var(--color-primary-bright);
  }
  .btn--ghost::after {
    content: " ]";
    color: var(--color-primary-bright);
  }
  .btn--ghost:hover {
    color: var(--color-primary-soft);
    background-color: var(--color-bg-overlay);
  }
  .btn--ghost:hover::before,
  .btn--ghost:hover::after {
    color: var(--color-primary-soft);
  }
  .btn--ghost:active {
    background-color: var(--color-bg-overlay-strong);
    transform: translateY(1px);
  }
</style>
