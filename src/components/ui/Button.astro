---
// Button primitive — placeholder, design-engineer will style
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { href, variant = "primary", size = "md", class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag href={href} class:list={["btn", `btn--${variant}`, `btn--${size}`, className]} {...rest}>
  <slot />
</Tag>
