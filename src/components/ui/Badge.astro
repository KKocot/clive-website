---
type Variant = "neutral" | "beta" | "success" | "warning" | "danger";

interface Props {
  variant?: Variant;
  pulse?: boolean;
  class?: string;
}

const {
  variant = "neutral",
  pulse = variant === "beta",
  class: className,
} = Astro.props;
---

<span
  class:list={["badge", `badge--${variant}`, className]}
  aria-label={variant === "beta" ? "Beta version" : undefined}
>
  {
    pulse && (
      <span class="badge__pulse" aria-hidden="true">
        <span class="badge__dot" />
        <span class="badge__ring" />
      </span>
    )
  }
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    line-height: 1.4;
    white-space: nowrap;
  }

  .badge--neutral {
    background-color: var(--color-bg-overlay);
    color: var(--color-text-muted);
    border-color: var(--color-border-default);
  }
  .badge--beta {
    background-color: rgba(185, 60, 91, 0.12);
    color: var(--color-accent-danger-text);
    border-color: var(--color-accent-danger);
    padding-left: 8px;
  }
  .badge--success {
    background-color: rgba(78, 191, 113, 0.12);
    color: var(--color-accent-success);
    border-color: rgba(78, 191, 113, 0.4);
  }
  .badge--warning {
    background-color: rgba(255, 166, 43, 0.12);
    color: var(--color-accent-warning);
    border-color: rgba(255, 166, 43, 0.4);
  }
  .badge--danger {
    background-color: rgba(185, 60, 91, 0.12);
    color: var(--color-accent-danger-text);
    border-color: var(--color-accent-danger);
  }

  .badge__pulse {
    position: relative;
    display: inline-flex;
    width: 6px;
    height: 6px;
    flex-shrink: 0;
  }
  .badge__dot {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    background-color: currentColor;
  }
  .badge__ring {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    border: 1px solid currentColor;
    animation: clive-pulse-ring 1.6s var(--ease-out-quad) infinite;
    transform-origin: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .badge__ring {
      animation: none;
      opacity: 0;
    }
  }
</style>
