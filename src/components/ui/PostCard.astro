---
import type { CollectionEntry } from "astro:content";
import Card from "./Card.astro";
import Badge from "./Badge.astro";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;

const { title, description, pubDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "short",
  day: "2-digit",
  year: "numeric",
});

const isoDate = pubDate.toISOString();

const visibleTags: string[] = (tags ?? []).slice(0, 3);

const href = `/blog/${post.id}/`;

// Reading time — body length not available in Content Layer index data,
// so estimate from description as a minimal heuristic; real value comes
// from the post page itself. Skip rendering when description is empty.
const wordsPerMinute = 200;
const wordCount = description.trim().split(/\s+/).length;
const estimatedMinutes = Math.max(1, Math.round(wordCount / wordsPerMinute));
const readingTimeLabel = `${estimatedMinutes} min read`;
---

<Card glow="indigo" fade={true} as="article" class={featured ? "post-card post-card--featured" : "post-card"}>
  <a href={href} class="post-card__link" aria-labelledby={`post-${post.id}-title`}>
    {
      visibleTags.length > 0 && (
        <ul class="post-card__tags" aria-label="Tags">
          {visibleTags.map((tag) => (
            <li>
              <Badge variant="neutral">{tag}</Badge>
            </li>
          ))}
        </ul>
      )
    }

    <h3 id={`post-${post.id}-title`} class="post-card__title">{title}</h3>

    <p class="post-card__description">{description}</p>

    <div class="post-card__meta">
      <time datetime={isoDate}>{formattedDate}</time>
      <span aria-hidden="true" class="post-card__meta-sep">·</span>
      <span>{readingTimeLabel}</span>
    </div>
  </a>
</Card>

<style>
  .post-card {
    display: block;
    height: 100%;
  }

  .post-card :global(.card__inner) {
    height: 100%;
    display: flex;
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: inherit;
    text-decoration: none;
    height: 100%;
    /* Make whole card clickable, but ensure focus-visible reaches Card */
    outline: none;
  }

  .post-card__link::after {
    /* Expand hit-area to whole card surface */
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .post-card__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
    /* clamp 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--duration-base) var(--ease-out-quint);
  }

  .post-card :global(.card:hover) .post-card__title,
  .post-card__link:focus-visible .post-card__title {
    color: var(--color-accent-primary);
  }

  .post-card__description {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__meta {
    margin-top: auto;
    padding-top: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
  }

  .post-card__meta-sep {
    color: var(--color-border-strong);
  }
</style>
