---
import CopyButton from "../islands/CopyButton";
import TerminalFrame from "../ui/TerminalFrame.astro";
import TuiPanel from "../ui/TuiPanel.astro";
import { LINKS } from "../../config/links";

const INSTALL_CMD = `bash <(curl -s ${LINKS.INSTALL_SCRIPT})`;

const firstStepsHtml = `<span class="install-step install-step--1"><span class="t-comment"># 1. TUI launches automatically</span>
<span class="t-comment"># After install, the Clive window opens inside Docker.</span>
<span class="t-comment"># Detach without stopping it:</span> <span class="t-accent">Ctrl-@, Ctrl-Q</span></span>

<span class="install-step install-step--2"><span class="t-comment"># 2. Create your profile</span>
<span class="t-prompt">$</span> clive configure profile create
<span class="t-comment"># Holds your accounts and wallet references.</span></span>

<span class="install-step install-step--3"><span class="t-comment"># 3. Set your Hive account</span>
<span class="t-prompt">$</span> clive configure working-account switch
<span class="t-comment"># Choose which Hive account this profile operates as.</span></span>

<span class="install-step install-step--4"><span class="t-comment"># 4. Add a private key</span>
<span class="t-prompt">$</span> clive configure key add
<span class="t-comment"># Stored in the encrypted Beekeeper wallet — never plaintext.</span></span>

<span class="install-step install-step--5"><span class="t-comment"># 5. Verify setup</span>
<span class="t-prompt">$</span> clive show balances
<span class="t-subtle">  HIVE: 0.000   HBD: 0.000   HP: 0.000</span>
<span class="t-prompt">$</span> <span class="t-cursor" aria-hidden="true">▌</span></span>`;
---

<TuiPanel title="$ bash <(curl -s get.clive.sh)" statusLeft="supported: linux, macos" id="install" class="install reveal-scroll">
  <div class="container-x">
    <header class="install__header reveal">
      <p class="install__eyebrow"><span aria-hidden="true">$ </span>get clive</p>
      <h2 id="install-heading" class="install__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>install
      </h2>
      <p class="install__lead">
        One command. Pulls Clive and sets up your Beekeeper wallet.
      </p>
    </header>

    <div
      class="install__prereq"
      role="note"
      aria-label="Prerequisite"
    >
      <span class="install__prereq-label">Prerequisite</span>
      <span class="install__prereq-text">
        <strong>Docker</strong> installed and running. The script pulls the
        <code>hiveio/clive</code> image and starts a container.
        <a
          href="https://docs.docker.com/get-docker/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Install Docker
          <span aria-hidden="true">↗</span>
        </a>
      </span>
    </div>

    <div
      class="install__warning"
      role="note"
      aria-label="Development notice"
    >
      <span class="install__warning-icon" aria-hidden="true">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </span>
      <p>
        Clive is in active development. Installation may require Hive
        infrastructure access — see docs.
      </p>
    </div>

    <div class="install__cmd">
      <div class="install__code-wrap">
        <pre class="install__code"><code>{INSTALL_CMD}</code></pre>
        <div class="install__copy">
          <CopyButton client:visible text={INSTALL_CMD} label="Copy" />
        </div>
      </div>
      <p class="install__note">
        Works on Linux, macOS 13+, and Windows (WSL2 required).
      </p>
    </div>

    <div
      class="install__steps reveal"
      role="region"
      aria-label="First steps after install"
    >
      <h3 class="install__steps-title sr-only">After install — first steps</h3>
      <TerminalFrame
        title="clive ▸ first steps"
        ariaLabel="First steps after install — terminal walkthrough"
        class="install__steps-frame"
      >
        <Fragment set:html={firstStepsHtml} />
      </TerminalFrame>
    </div>

    <p class="install__doc-link">
      <a href={LINKS.GITLAB_INSTALL} rel="noopener noreferrer" target="_blank">
        Read full installation guide
        <span aria-hidden="true">↗</span>
      </a>
      <span class="install__doc-link-sep" aria-hidden="true">·</span>
      <a
        href={LINKS.GITLAB_CLI_REFERENCE}
        rel="noopener noreferrer"
        target="_blank"
      >
        Browse all CLI commands
        <span aria-hidden="true">↗</span>
      </a>
    </p>
  </div>
</TuiPanel>

<style>
  .install {
    background-color: var(--color-bg-section-tinted);
    padding-block: var(--section-y);
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (min-width: 64rem) {
    .install {
      padding-block: var(--section-y-lg);
    }
  }

  .install__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .install__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .install__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .install__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .install__prereq {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-default);
    background-color: var(--color-bg-overlay);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    max-width: 42rem;
    margin-inline: auto;
  }
  .install__prereq-label {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-bright);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-elevated);
  }
  .install__prereq-text strong {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }
  .install__prereq-text code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
  }
  .install__prereq-text a {
    color: var(--color-primary-bright);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out-quad), color var(--duration-fast) var(--ease-out-quad);
    white-space: nowrap;
  }
  .install__prereq-text a:hover {
    color: var(--color-primary-soft);
    border-bottom-color: currentColor;
  }

  .install__warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-accent-warning);
    background-color: rgba(255, 166, 43, 0.08);
    color: var(--color-text);
    margin-bottom: var(--space-6);
    max-width: 42rem;
    margin-inline: auto;
  }
  .install__warning p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }
  .install__warning-icon {
    flex-shrink: 0;
    color: var(--color-accent-warning);
    margin-top: 2px;
  }

  .install__cmd {
    max-width: 42rem;
    margin-inline: auto;
  }

  .install__code-wrap {
    position: relative;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border-bright);
    border-radius: var(--radius-md);
  }

  .install__code {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    padding-right: 6rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    overflow-x: auto;
  }

  .install__copy {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
  }

  .install__note {
    margin: var(--space-3) 0 0;
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  /* After install — first steps (TUI panel) */
  .install__steps {
    margin-top: var(--space-10);
    max-width: 48rem;
    margin-inline: auto;
  }

  /* Visually hidden heading — kept for AT and document outline */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Terminal token highlights specific to the first-steps panel.
     Using :global because the panel content is rendered via set:html. */
  :global(.t-comment) {
    color: var(--color-text-subtle);
    font-style: italic;
  }
  :global(.t-prompt) {
    color: var(--color-primary-bright);
    font-weight: var(--font-weight-semibold);
  }
  :global(.t-cursor) {
    display: inline-block;
    color: var(--color-primary-bright);
    animation: install-cursor-blink 1.1s steps(1, end) infinite;
  }

  @keyframes install-cursor-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.t-cursor) {
      animation: none;
      opacity: 0.85;
    }
  }

  /* Sequential step reveal — typing feel for first-steps code block */
  :global(.install-step) {
    display: inline;
    opacity: 0;
    animation: install-step-in var(--duration-normal) var(--ease-out) forwards;
  }
  :global(.install-step--1) { animation-delay: 0ms; }
  :global(.install-step--2) { animation-delay: 200ms; }
  :global(.install-step--3) { animation-delay: 400ms; }
  :global(.install-step--4) { animation-delay: 600ms; }
  :global(.install-step--5) { animation-delay: 800ms; }

  @keyframes install-step-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.install-step) {
      animation: none;
      opacity: 1;
    }
  }

  /* Mobile: tighten padding + drop font size for narrow viewports */
  @media (max-width: 32rem) {
    .install__steps :global(.terminal__body) {
      font-size: 0.8125rem;
      padding: var(--space-3) var(--space-4);
    }
  }

  .install__doc-link {
    margin: var(--space-8) auto 0;
    max-width: 48rem;
    font-size: var(--text-sm);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
  .install__doc-link a {
    color: var(--color-primary-bright);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out-quad), color var(--duration-fast) var(--ease-out-quad);
  }
  .install__doc-link a:hover {
    color: var(--color-primary-soft);
    border-bottom-color: currentColor;
  }
  .install__doc-link-sep {
    color: var(--color-text-subtle);
  }

  /* Copy button (global since solid renders raw markup) */
  :global(.copy-btn) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    height: 32px;
    padding: 0 var(--space-3);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-surface);
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out-quad),
      background-color var(--duration-fast) var(--ease-out-quad),
      border-color var(--duration-fast) var(--ease-out-quad);
  }
  :global(.copy-btn:hover) {
    color: var(--color-primary-bright);
    background-color: var(--color-bg-elevated);
    border-color: var(--color-border-bright);
  }
  :global(.copy-btn[data-copied="true"]) {
    color: var(--color-accent-success);
    border-color: rgba(78, 191, 113, 0.4);
  }
  :global(.copy-btn:focus-visible) {
    outline: none;
    box-shadow: var(--shadow-focus-ring);
  }
  :global(.copy-btn__icon) {
    display: inline-flex;
  }
</style>
