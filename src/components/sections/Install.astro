---
import CopyButton from "../islands/CopyButton";
import WorkflowTabs from "../islands/WorkflowTabs";
import TerminalFrame from "../ui/TerminalFrame.astro";
import TuiPanel from "../ui/TuiPanel.astro";
import { LINKS } from "../../config/links";

const INSTALL_CMD = `bash <(curl -s ${LINKS.INSTALL_SCRIPT})`;

const firstStepsHtml = `<div class="install-tui">
  <header class="install-tui__header">
    <span class="install-tui__header-left">
      <span class="install-tui__header-user">alice / <span class="t-emerald">@alice</span></span>
      <span class="install-tui__header-unlock t-emerald">UNLOCKED</span>
    </span>
    <span class="install-tui__header-right">
      <span class="install-tui__header-tab">Dashboard</span>
      <span class="install-tui__header-tab install-tui__header-tab--active">Setup</span>
      <span class="install-tui__header-step t-dim">Step 1 of 4</span>
    </span>
  </header>

  <div class="install-tui__body">
    <div class="install-tui__section">
      <div class="install-tui__section-title">PROFILE SETUP</div>
      <div class="install-tui__field">
        <span class="install-tui__label install-tui__label--req"><span class="install-tui__asterisk">*</span> Profile name</span>
        <span class="install-tui__input"><span class="t-emerald">default</span></span>
      </div>
      <div class="install-tui__field">
        <span class="install-tui__label install-tui__label--req"><span class="install-tui__asterisk">*</span> Working account</span>
        <span class="install-tui__input"><span class="t-accent">alice</span></span>
      </div>
    </div>

    <div class="install-tui__section">
      <div class="install-tui__section-title">NODE SELECTION</div>
      <div class="install-tui__nodes">
        <span class="install-tui__node install-tui__node--active"><span class="t-emerald">&#x25CF;</span> api.hive.blog</span>
        <span class="install-tui__node"><span class="t-dim">&#x25CB;</span> api.deathwing.me</span>
        <span class="install-tui__node"><span class="t-dim">&#x25CB;</span> api.openhive.network</span>
      </div>
    </div>

    <div class="install-tui__section">
      <div class="install-tui__section-title">KEY MANAGEMENT</div>
      <div class="install-tui__field">
        <span class="install-tui__label install-tui__label--req"><span class="install-tui__asterisk">*</span> Wallet</span>
        <span class="install-tui__input"><span class="t-emerald">&#x1f512; encrypted (Beekeeper)</span></span>
      </div>
      <div class="install-tui__actions">
        <span class="install-tui__btn install-tui__btn--primary">Continue &rarr;</span>
      </div>
    </div>
  </div>

  <footer class="install-tui__footer">
    <span><span class="install-tui__key">Tab</span> <span class="t-dim">next</span></span>
    <span><span class="install-tui__key">Enter</span> <span class="t-dim">confirm</span></span>
    <span><span class="install-tui__key">esc</span> <span class="t-dim">back</span></span>
    <span><span class="install-tui__key">^l</span> <span class="t-dim">Lock</span></span>
    <span><span class="install-tui__key">^s</span> <span class="t-dim">Settings</span></span>
  </footer>
</div>`;

const cliStepsHtml = `<span class="install-step install-step--1"><span class="t-comment"># 1. Run Clive in CLI mode (non-interactive)</span>
<span class="t-prompt">$</span> clive <span class="t-cyan">-n</span>
<span class="t-accent">  Using beekeeper at http://127.0.0.1:39507</span>
<span class="t-comment"># Skip the TUI — work directly from your shell.</span></span>

<span class="install-step install-step--2"><span class="t-comment"># 2. Create your profile</span>
<span class="t-prompt">$</span> clive configure profile create <span class="t-cyan">-n</span> my-profile
<span class="t-emerald">  Profile 'my-profile' created.</span></span>

<span class="install-step install-step--3"><span class="t-comment"># 3. Set your Hive account</span>
<span class="t-prompt">$</span> clive configure working-account set alice <span class="t-cyan">-n</span>
<span class="t-emerald">  Working account set to 'alice'.</span></span>

<span class="install-step install-step--4"><span class="t-comment"># 4. Add a key to the wallet</span>
<span class="t-prompt">$</span> clive configure key add <span class="t-cyan">-n</span>
<span class="t-emerald">  Key added to Beekeeper wallet.</span></span>

<span class="install-step install-step--5"><span class="t-comment"># 5. Verify your setup</span>
<span class="t-prompt">$</span> clive show balances <span class="t-cyan">-n</span>
<span class="t-dim">  ┌──────────┬───────────────┬──────────────┐</span>
<span class="t-dim">  │</span> <span class="t-emerald">Liquid</span>   <span class="t-dim">│</span>   0.000 HIVE  <span class="t-dim">│</span>  0.000 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Savings</span>  <span class="t-dim">│</span>   0.000 HIVE  <span class="t-dim">│</span>  0.000 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Stake</span>    <span class="t-dim">│</span>   0.000 HP    <span class="t-dim">│</span>  0.0 VESTS  <span class="t-dim">│</span>
<span class="t-dim">  └──────────┴───────────────┴──────────────┘</span>
<span class="t-prompt">$</span> <span class="t-cursor" aria-hidden="true">▌</span></span>`;
---

<TuiPanel title="$ bash <(curl -s get.clive.sh)" statusLeft="supported: linux, macos" id="install" class="install reveal-scroll">
  <div class="container-x">
    <header class="install__header reveal">
      <p class="install__eyebrow"><span aria-hidden="true">$ </span>get clive</p>
      <h2 id="install-heading" class="install__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>install
      </h2>
      <p class="install__lead">
        One command. Pulls Clive and sets up your Beekeeper wallet.
      </p>
    </header>

    <div
      class="install__prereq"
      role="note"
      aria-label="Prerequisite"
    >
      <span class="install__prereq-label">Prerequisite</span>
      <span class="install__prereq-text">
        <strong>Docker</strong> installed and running. The script pulls the
        <code>hiveio/clive</code> image and starts a container.
        <a
          href="https://docs.docker.com/get-docker/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Install Docker
          <span aria-hidden="true">↗</span>
        </a>
      </span>
    </div>

    <div class="install__cmd">
      <div class="install__code-wrap">
        <pre class="install__code"><code>{INSTALL_CMD}</code></pre>
        <div class="install__copy">
          <CopyButton client:visible text={INSTALL_CMD} label="Copy" />
        </div>
      </div>
      <p class="install__note">
        Works on Linux, macOS 13+, and Windows (WSL2 required).
      </p>
    </div>

    <div
      class="install__steps reveal"
      role="region"
      aria-label="First steps after install"
    >
      <h3 class="install__steps-title sr-only">After install — first steps</h3>
      <TerminalFrame
        title="clive ▸ first steps"
        ariaLabel="First steps after install — terminal walkthrough"
        class="install__steps-frame"
        as="div"
      >
        <WorkflowTabs client:visible panelId="install" tuiHtml={firstStepsHtml} cliHtml={cliStepsHtml} />
      </TerminalFrame>
    </div>

    <p class="install__doc-link">
      <a href={LINKS.GITLAB_INSTALL} rel="noopener noreferrer" target="_blank">
        Read full installation guide
        <span aria-hidden="true">↗</span>
      </a>
      <span class="install__doc-link-sep" aria-hidden="true">·</span>
      <a
        href={LINKS.GITLAB_CLI_REFERENCE}
        rel="noopener noreferrer"
        target="_blank"
      >
        Browse all CLI commands
        <span aria-hidden="true">↗</span>
      </a>
    </p>
  </div>
</TuiPanel>

<style>
  :global(.install) {
    background-color: var(--color-bg-section-tinted);
    padding: var(--space-3);
    min-height: calc(100dvh - var(--header-h));
    transition: background-color var(--mode-transition, 300ms) ease;
  }

  .install__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .install__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .install__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .install__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .install__prereq {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-default);
    background-color: var(--color-bg-overlay);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    max-width: 42rem;
    margin-inline: auto;
  }
  .install__prereq-label {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-bright);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-elevated);
  }
  .install__prereq-text strong {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }
  .install__prereq-text code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
  }
  .install__prereq-text a {
    color: var(--color-primary-bright);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out-quad), color var(--duration-fast) var(--ease-out-quad);
    white-space: nowrap;
  }
  .install__prereq-text a:hover {
    color: var(--color-primary-soft);
    border-bottom-color: currentColor;
  }

  .install__cmd {
    max-width: 42rem;
    margin-inline: auto;
  }

  .install__code-wrap {
    position: relative;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border-bright);
    border-radius: var(--radius-md);
  }

  .install__code {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    padding-right: 6rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    overflow-x: auto;
  }

  .install__copy {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
  }

  .install__note {
    margin: var(--space-3) 0 0;
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  /* After install — first steps (TUI panel) */
  .install__steps {
    margin-top: var(--space-10);
    max-width: 48rem;
    margin-inline: auto;
  }

  /* Workflow panel — inherits font/color from terminal__body */
  .install__steps :global(.workflow-tabs__panel) {
    white-space: pre-wrap;
  }

  /* When TUI mode is active in install, switch to normal flow */
  :global(.install__steps [data-mode="tui"] .workflow-tabs__panel) {
    white-space: normal;
  }

  /* ============================================================
   * Install TUI — setup wizard panel layout
   * ============================================================ */
  :global(.install-tui) {
    white-space: normal;
    font-family: var(--font-mono);
    font-size: clamp(0.6875rem, 0.6rem + 0.35vw, 0.8125rem);
    line-height: 1.4;
    color: var(--mode-text, var(--color-text));
    background-color: var(--mode-bg, transparent);
    border-radius: var(--radius-md);
    transition: background-color 300ms ease, color 300ms ease;
  }

  :global(.install-tui__header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    font-size: var(--text-xs);
    transition: background-color 300ms ease, border-color 300ms ease;
  }
  :global(.install-tui__header-left),
  :global(.install-tui__header-right) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  :global(.install-tui__header-user) {
    font-size: 0.875em;
  }
  :global(.install-tui__header-unlock) {
    font-size: 0.75em;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
  }
  :global(.install-tui__header-tab) {
    padding: 0.125rem 0.5rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    border-radius: var(--radius-xs);
  }
  :global(.install-tui__header-tab--active) {
    background-color: var(--mode-border, rgba(96, 165, 250, 0.15));
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }
  :global(.install-tui__header-step) {
    margin-left: var(--space-1);
    font-size: 0.875em;
  }

  :global(.install-tui__body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
  }

  :global(.install-tui__section) {
    border: 1px solid var(--mode-border, var(--color-border-default));
    border-radius: var(--radius-xs);
    padding: var(--space-2) var(--space-3);
    transition: border-color 300ms ease;
  }

  :global(.install-tui__section-title) {
    font-size: 0.6875em;
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--mode-text-muted, var(--color-text-muted));
    margin-bottom: var(--space-1);
  }

  :global(.install-tui__field) {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-1);
  }

  :global(.install-tui__label) {
    min-width: 7rem;
    text-align: right;
    flex-shrink: 0;
    font-size: 0.8125em;
    color: var(--mode-text-muted, var(--color-text-muted));
  }
  :global(.install-tui__label--req) {
    color: var(--mode-accent-success, var(--color-accent-success));
  }
  :global(.install-tui__asterisk) {
    color: var(--mode-accent-success, var(--color-accent-success));
    font-weight: var(--font-weight-bold);
  }

  :global(.install-tui__input) {
    flex: 1;
    padding: 0.125rem var(--space-2);
    border: 1px solid var(--mode-accent-success, #22c55e);
    border-radius: var(--radius-xs);
    font-size: 0.875em;
    transition: border-color 300ms ease;
  }

  :global(.install-tui__nodes) {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.875em;
  }

  :global(.install-tui__node) {
    padding: 0.0625rem var(--space-2);
    border-radius: var(--radius-xs);
  }

  :global(.install-tui__node--active) {
    background-color: var(--mode-border, rgba(96, 165, 250, 0.10));
  }

  :global(.install-tui__actions) {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-top: var(--space-2);
    flex-wrap: wrap;
  }

  :global(.install-tui__btn) {
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    font-size: 0.875em;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-xs);
  }
  :global(.install-tui__btn--primary) {
    background-color: var(--mode-accent-success, #22c55e);
    color: #fff;
  }

  :global(.install-tui__footer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-1) var(--space-3);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-top: 1px solid var(--mode-border, var(--color-border-default));
    font-size: 0.6875rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: background-color 300ms ease, border-color 300ms ease;
  }

  :global(.install-tui__key) {
    display: inline-block;
    padding: 0 0.25rem;
    background-color: rgba(255, 166, 43, 0.15);
    border: 1px solid rgba(255, 166, 43, 0.30);
    border-radius: 2px;
    color: var(--color-accent-warning);
    font-size: 0.9em;
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    margin-right: 0.125rem;
  }

  /* Mobile adjustments for TUI setup */
  @media (max-width: 32rem) {
    :global(.install-tui__field) {
      flex-direction: column;
      gap: var(--space-1);
    }
    :global(.install-tui__label) {
      text-align: left;
      min-width: unset;
    }
  }

  /* Visually hidden heading — kept for AT and document outline */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Terminal token highlights (.t-*) — defined in src/styles/tokens.css */

  /* Sequential step reveal — typing feel for CLI steps code block */
  :global(.install-step) {
    display: inline;
    opacity: 0;
    animation: install-step-in var(--duration-normal) var(--ease-out) forwards;
  }
  :global(.install-step--1) { animation-delay: 0ms; }
  :global(.install-step--2) { animation-delay: 200ms; }
  :global(.install-step--3) { animation-delay: 400ms; }
  :global(.install-step--4) { animation-delay: 600ms; }
  :global(.install-step--5) { animation-delay: 800ms; }

  @keyframes install-step-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.install-step) {
      animation: none;
      opacity: 1;
    }
  }

  /* Mobile: tighten padding + drop font size for narrow viewports */
  @media (max-width: 32rem) {
    .install__steps :global(.terminal__body) {
      font-size: 0.8125rem;
      padding: var(--space-3) var(--space-4);
    }
  }

  .install__doc-link {
    margin: var(--space-8) auto 0;
    max-width: 48rem;
    font-size: var(--text-sm);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
  .install__doc-link a {
    color: var(--color-primary-bright);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out-quad), color var(--duration-fast) var(--ease-out-quad);
  }
  .install__doc-link a:hover {
    color: var(--color-primary-soft);
    border-bottom-color: currentColor;
  }
  .install__doc-link-sep {
    color: var(--color-text-subtle);
  }

  /* Copy button (global since solid renders raw markup) */
  :global(.copy-btn) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    height: 32px;
    padding: 0 var(--space-3);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-surface);
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out-quad),
      background-color var(--duration-fast) var(--ease-out-quad),
      border-color var(--duration-fast) var(--ease-out-quad);
  }
  :global(.copy-btn:hover) {
    color: var(--color-primary-bright);
    background-color: var(--color-bg-elevated);
    border-color: var(--color-border-bright);
  }
  :global(.copy-btn[data-copied="true"]) {
    color: var(--color-accent-success);
    border-color: rgba(78, 191, 113, 0.4);
  }
  :global(.copy-btn:focus-visible) {
    outline: none;
    box-shadow: var(--shadow-focus-ring);
  }
  :global(.copy-btn__icon) {
    display: inline-flex;
  }
</style>
