---
import Card from "../ui/Card.astro";

type Glow = "blue" | "cyan" | "green" | "crimson" | "hive";

interface Feature {
  title: string;
  desc: string;
  glow: Glow;
  glyph: string;
  colorVar: string;
}

const features: Feature[] = [
  {
    title: "Dual interface",
    desc: "Run interactively as a full TUI, or pipe commands through CLI for scripting.",
    glow: "blue",
    glyph: "[||]",
    colorVar: "var(--color-primary-bright)",
  },
  {
    title: "Encrypted wallets",
    desc: "Beekeeper stores keys in encrypted wallets — never raw on disk. Unlock once.",
    glow: "green",
    glyph: "[#]",
    colorVar: "var(--color-accent-success)",
  },
  {
    title: "Mouse-driven TUI",
    desc: "Click buttons inside your terminal. Midnight Commander aesthetics, modern ergonomics.",
    glow: "cyan",
    glyph: "[+]",
    colorVar: "var(--color-primary-bright)",
  },
  {
    title: "Profile system",
    desc: "Working account, watched accounts, key aliases, and node list — bundled per profile.",
    glow: "blue",
    glyph: "[@]",
    colorVar: "var(--color-primary)",
  },
  {
    title: "Transaction cart",
    desc: "Batch operations, auto-pick the right key, sign and broadcast atomically.",
    glow: "crimson",
    glyph: "[$]",
    colorVar: "var(--color-accent-danger-text)",
  },
  {
    title: "Hive blockchain native",
    desc: "Transfers, delegations, votes, governance, recovery, RC — every Hive op, terminal-native.",
    glow: "hive",
    glyph: "[!]",
    colorVar: "var(--color-hive-text)",
  },
];
---

<section
  id="features"
  class="features"
  aria-labelledby="features-heading"
>
  <div class="container-x">
    <header class="features__header reveal">
      <p class="features__eyebrow"><span aria-hidden="true">// </span>why clive</p>
      <h2 id="features-heading" class="features__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>features
      </h2>
      <p class="features__lead">
        Six things Clive gets right — encrypted, scriptable, terminal-native.
      </p>
    </header>

    <ul class="features__grid" role="list">
      {
        features.map((f, i) => (
          <li class={`reveal reveal--delay-${(i % 3) + 1}`}>
            <Card glow={f.glow}>
              <span
                class="feature__icon"
                style={`color: ${f.colorVar}`}
                aria-hidden="true"
              >
                {f.glyph}
              </span>
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__desc">{f.desc}</p>
            </Card>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features {
    background-color: var(--color-bg-surface);
    padding-block: var(--section-y);
  }
  @media (min-width: 64rem) {
    .features {
      padding-block: var(--section-y-lg);
    }
  }

  .features__header {
    max-width: 48rem;
    margin-bottom: var(--space-12);
  }

  .features__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .features__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
    color: var(--color-text);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .features__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .features__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .features__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 64rem) {
    .features__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .features__grid > li {
    display: flex;
  }
  .features__grid > li > :global(.card) {
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .features__grid > li > :global(.card) > :global(.card__inner) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .feature__icon {
    width: auto;
    height: auto;
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: var(--space-3);
    display: inline-block;
  }

  .feature__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
    margin: 0 0 var(--space-2);
    color: var(--color-text);
  }

  .feature__desc {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 38ch;
    margin: 0;
  }
</style>
