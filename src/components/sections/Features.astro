---
import Card from "../ui/Card.astro";

type Glow = "blue" | "cyan" | "green" | "crimson" | "hive";

interface Feature {
  title: string;
  desc: string;
  glow: Glow;
  iconKey: "split" | "key" | "mouse" | "user" | "zap" | "cart";
}

const features: Feature[] = [
  {
    title: "Dual interface",
    desc: "Run interactively as a full TUI, or pipe commands through CLI for scripting.",
    glow: "blue",
    iconKey: "split",
  },
  {
    title: "Encrypted wallets",
    desc: "Beekeeper stores keys in encrypted wallets — never raw on disk. Unlock once.",
    glow: "green",
    iconKey: "key",
  },
  {
    title: "Mouse-driven TUI",
    desc: "Click buttons inside your terminal. Midnight Commander aesthetics, modern ergonomics.",
    glow: "cyan",
    iconKey: "mouse",
  },
  {
    title: "Profile system",
    desc: "Working account, watched accounts, key aliases, and node list — bundled per profile.",
    glow: "blue",
    iconKey: "user",
  },
  {
    title: "Transaction cart",
    desc: "Batch operations, auto-pick the right key, sign and broadcast atomically.",
    glow: "crimson",
    iconKey: "cart",
  },
  {
    title: "Hive blockchain native",
    desc: "Transfers, delegations, votes, governance, recovery, RC — every Hive op, terminal-native.",
    glow: "hive",
    iconKey: "zap",
  },
];

const glowToColorVar: Record<Glow, string> = {
  blue: "var(--color-primary)",
  cyan: "var(--color-primary-bright)",
  green: "var(--color-accent-success)",
  crimson: "var(--color-accent-danger-text)",
  hive: "var(--color-hive-text)",
};
---

<section
  id="features"
  class="features"
  aria-labelledby="features-heading"
>
  <div class="container-x">
    <header class="features__header reveal">
      <p class="features__eyebrow">Why Clive</p>
      <h2 id="features-heading" class="features__title">
        Built for power users
      </h2>
      <p class="features__lead">
        Six things Clive gets right — encrypted, scriptable, terminal-native.
      </p>
    </header>

    <ul class="features__grid" role="list">
      {
        features.map((f, i) => (
          <li class={`reveal reveal--delay-${(i % 3) + 1}`}>
            <Card glow={f.glow} fade>
              <div
                class="feature__icon"
                style={`color: ${glowToColorVar[f.glow]}`}
                aria-hidden="true"
              >
                {f.iconKey === "split" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="4" width="18" height="16" rx="2" />
                    <line x1="12" y1="4" x2="12" y2="20" />
                  </svg>
                )}
                {f.iconKey === "key" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="8" cy="15" r="4" />
                    <line x1="10.85" y1="12.15" x2="20" y2="3" />
                    <line x1="18" y1="5" x2="20" y2="7" />
                    <line x1="15" y1="8" x2="17" y2="10" />
                  </svg>
                )}
                {f.iconKey === "mouse" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 3l14 8-6 2-3 7-5-17z" />
                    <line x1="11" y1="13" x2="18" y2="20" />
                  </svg>
                )}
                {f.iconKey === "user" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 21c0-4 3.6-7 8-7s8 3 8 7" />
                    <circle cx="18" cy="6" r="1.5" />
                  </svg>
                )}
                {f.iconKey === "zap" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                  </svg>
                )}
                {f.iconKey === "cart" && (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="9" cy="20" r="1.75" />
                    <circle cx="18" cy="20" r="1.75" />
                    <path d="M3 4h2.2l2.4 11.2a2 2 0 0 0 2 1.6h7.8a2 2 0 0 0 2-1.5L21 8H6" />
                  </svg>
                )}
              </div>
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__desc">{f.desc}</p>
            </Card>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features {
    background-color: var(--color-bg-surface);
    padding-block: var(--section-y);
  }
  @media (min-width: 64rem) {
    .features {
      padding-block: var(--section-y-lg);
    }
  }

  .features__header {
    max-width: 48rem;
    margin-bottom: var(--space-12);
  }

  .features__eyebrow {
    margin: 0 0 var(--space-3);
    font-size: 0.8125rem;            /* 13px */
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-bright);
    opacity: 0.9;
  }

  .features__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-3);
    color: var(--color-text);
  }

  .features__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .features__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .features__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 64rem) {
    .features__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .features__grid > li {
    display: flex;
  }
  .features__grid > li > :global(.card) {
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .features__grid > li > :global(.card) > :global(.card__inner) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .feature__icon {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border-subtle);
    margin-bottom: var(--space-4);
    transition: background-color var(--duration-base) var(--ease-out-quint);
  }

  .feature__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
    margin: 0 0 var(--space-2);
    color: var(--color-text);
  }

  .feature__desc {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 38ch;
    margin: 0;
  }
</style>
