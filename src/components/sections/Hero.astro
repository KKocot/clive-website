---
import Button from "../ui/Button.astro";
import TerminalFrame from "../ui/TerminalFrame.astro";
import { LINKS } from "../../config/links";

const GITLAB_URL = LINKS.GITLAB;

const heroTerminalHtml = `<span class="t-accent">Clive</span> <span class="t-dim">·</span> <span class="t-emerald">@alice</span> <span class="t-dim">·</span> <span class="t-accent">HIVE 1,234.567</span>

Operations          Status
<span class="t-dim">─────────────</span>       <span class="t-dim">──────────</span>
<span class="t-accent">></span> Transfer          HBD <span class="t-emerald">89.42</span>
  Delegate          HP  <span class="t-emerald">4,500.00</span>
  Vote witness      Voting <span class="t-amber">100%</span>

<span class="t-subtle">Press [^/v] navigate  [Enter] select</span>`;
---

<section
  id="hero"
  class="hero"
  aria-labelledby="hero-heading"
>
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container-x hero__inner">
    <div class="hero__content">
      <div class="reveal reveal--delay-1 hero__meta">
        <span class="hero__eyebrow">CLI for Hive blockchain</span>
        <span class="hero__separator" aria-hidden="true">·</span>
        <span class="hero__badge-beta">BETA</span>
      </div>

      <h1
        id="hero-heading"
        class="h-display reveal reveal--delay-2 hero__heading"
      >
        Clive — power-user wallet for <span class="hero__heading-accent"
          >Hive</span
        >
      </h1>

      <p class="reveal reveal--delay-3 hero__subhead">
        Encrypted keys, mouse-driven TUI, full blockchain operations — straight
        from your terminal.
      </p>

      <div class="reveal reveal--delay-4 hero__ctas">
        <Button variant="primary" size="lg" href="#install">
          Get Clive
          <span slot="icon-end" aria-hidden="true">→</span>
        </Button>
        <Button
          variant="secondary"
          size="lg"
          href={GITLAB_URL}
          rel="noopener noreferrer"
          target="_blank"
        >
          View on GitLab
          <span slot="icon-end" aria-hidden="true">↗</span>
        </Button>
      </div>

      <p class="reveal reveal--delay-4 hero__note">
        Open source · Built for Hive
      </p>
    </div>

    <div class="hero__visual reveal reveal--delay-3">
      <TerminalFrame title="clive — main view" ariaLabel="Clive TUI preview">
        <Fragment set:html={heroTerminalHtml} />
      </TerminalFrame>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(560px, 80vh, 760px);
    display: flex;
    align-items: center;
    padding-block: var(--section-y);
    overflow: hidden;
  }
  @media (min-width: 64rem) {
    .hero {
      padding-block: var(--section-y-lg);
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--hero-gradient);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 32rem;
  }

  .hero__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .hero__eyebrow {
    font-size: 0.8125rem;            /* 13px */
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-bright);
    opacity: 0.9;
  }
  .hero__separator {
    color: var(--color-text-subtle);
    font-size: 0.8125rem;
    line-height: 1;
  }
  .hero__badge-beta {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-accent-danger);
    background-color: rgba(196, 75, 110, 0.12);
    color: var(--color-accent-danger-text);
    font-size: 0.6875rem;            /* 11px */
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .hero__heading {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
  }
  .hero__heading-accent {
    color: var(--color-primary-bright);
  }

  .hero__subhead {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .hero__visual {
    width: 100%;
  }

  /* Terminal token highlights */
  :global(.t-accent) {
    color: var(--color-primary-bright);
  }
  :global(.t-emerald) {
    color: var(--color-accent-success);
  }
  :global(.t-amber) {
    color: var(--color-accent-warning);
  }
  :global(.t-dim) {
    color: var(--color-text-subtle);
  }
  :global(.t-subtle) {
    color: var(--color-text-muted);
  }
</style>
