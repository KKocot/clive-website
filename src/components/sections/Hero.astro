---
import Button from "../ui/Button.astro";
import TerminalFrame from "../ui/TerminalFrame.astro";
import TypewriterText from "../islands/TypewriterText.tsx";
import { LINKS } from "../../config/links";

const GITLAB_URL = LINKS.GITLAB;

const heroTerminalHtml = `<span class="t-accent">Clive</span> <span class="t-dim">·</span> <span class="t-emerald">@alice</span> <span class="t-dim">·</span> <span class="t-accent">HIVE 1,234.567</span>

Operations          Status
<span class="t-dim">─────────────</span>       <span class="t-dim">──────────</span>
<span class="t-accent">></span> Transfer          HBD <span class="t-emerald">89.42</span>
  Delegate          HP  <span class="t-emerald">4,500.00</span>
  Vote witness      Voting <span class="t-amber">100%</span>

<span class="t-subtle">Press [^/v] navigate  [Enter] select</span>`;
---

<section
  id="hero"
  class="hero"
  aria-labelledby="hero-heading"
>
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container-x hero__inner">
    <div class="hero__content">
      <div class="reveal reveal--delay-1 hero__meta">
        <span class="hero__eyebrow"><span aria-hidden="true">$ </span>clive --help</span>
      </div>

      <h1
        id="hero-heading"
        class="h-display reveal reveal--delay-2 hero__heading"
      >
        <TypewriterText
          client:visible
          text="clive — power-user wallet for "
          accentText="hive"
          speed={50}
          delay={400}
        />
      </h1>

      <p class="reveal reveal--delay-3 hero__subhead">
        Encrypted keys, mouse-driven TUI, full blockchain operations — straight
        from your terminal.
      </p>

      <div class="reveal reveal--delay-4 hero__ctas">
        <Button variant="primary" size="lg" href="#install">
          Get Clive
          <span slot="icon-end" aria-hidden="true">→</span>
        </Button>
        <Button
          variant="secondary"
          size="lg"
          href={GITLAB_URL}
          rel="noopener noreferrer"
          target="_blank"
        >
          View on GitLab
          <span slot="icon-end" aria-hidden="true">↗</span>
        </Button>
      </div>

      <p class="reveal reveal--delay-4 hero__note">
        Open source · Built for Hive
      </p>
    </div>

    <div class="hero__visual reveal reveal--delay-3">
      <TerminalFrame title="clive — main view" ariaLabel="Clive TUI preview">
        <Fragment set:html={heroTerminalHtml} />
      </TerminalFrame>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-block: var(--section-y);
    overflow: hidden;
  }
  @media (min-width: 64rem) {
    .hero {
      padding-block: var(--section-y-lg);
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--hero-gradient);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 32rem;
  }

  .hero__meta {
    display: inline-block;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .hero__heading {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(2rem, 4.6vw, 3.5rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
  }
  /* Typewriter island — grid-stack technique for zero CLS
   * SSR: sizer visible (full text + cursor), overlay hidden
   * After hydration: sizer hidden, overlay active with typing animation */
  .hero__heading :global(.typewriter) {
    display: inline-grid;
  }
  .hero__heading :global(.typewriter__sizer),
  .hero__heading :global(.typewriter__overlay) {
    grid-area: 1 / 1;
  }

  /* Sizer: visible on SSR, hidden after JS hydration */
  .hero__heading :global(.typewriter__sizer) {
    /* visible by default — SSR shows full text */
  }
  .hero__heading :global(.typewriter__sizer--hidden) {
    visibility: hidden;
  }

  /* Overlay: hidden on SSR, visible after JS hydration */
  .hero__heading :global(.typewriter__overlay) {
    visibility: hidden;
  }
  .hero__heading :global(.typewriter__overlay--active) {
    visibility: visible;
  }

  .hero__heading :global(.typewriter__accent) {
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor) {
    display: inline-block;
    margin-left: 0.02em;
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor--blink) {
    animation: clive-cursor-blink var(--cursor-blink-duration) steps(2, end) infinite;
  }
  @keyframes clive-cursor-blink {
    0%, 49.99% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__heading :global(.typewriter__cursor--blink) {
      animation: none;
      opacity: 1;
    }
  }

  .hero__subhead {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .hero__visual {
    width: 100%;
  }

  /* Terminal token highlights */
  :global(.t-accent) {
    color: var(--color-primary-bright);
  }
  :global(.t-emerald) {
    color: var(--color-accent-success);
  }
  :global(.t-amber) {
    color: var(--color-accent-warning);
  }
  :global(.t-dim) {
    color: var(--color-text-subtle);
  }
  :global(.t-subtle) {
    color: var(--color-text-muted);
  }
</style>
