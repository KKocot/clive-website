              <div class="hero__tui-mana-pct">100.00 % <span class="hero__tui-mana-type">DOWNVOTING</span></div>
              <div class="hero__tui-mana-detail">250.000 HP <span class="t-emerald">Full!</span></div>
            </div>
          </div>
        </div>
        <div class="hero__tui-card-bottom">
          <div class="hero__tui-last">
            <div class="hero__tui-last-label">LAST:</div>
            <div class="hero__tui-last-row"><span class="t-dim">History entry:</span> 2026-02-11T13:54:18</div>
            <div class="hero__tui-last-row"><span class="t-dim">Account update:</span> never</div>
          </div>
          <div class="hero__tui-table">
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">LIQUID</span>
              <span class="hero__tui-cell-val">1000.000 HIVE</span>
              <span class="hero__tui-cell-val">1000.000 HBD</span>
            </div>
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">SAVINGS</span>
              <span class="hero__tui-cell-val">0.000 HIVE</span>
              <span class="hero__tui-cell-val">0.000 HBD</span>
            </div>
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">STAKE</span>
              <span class="hero__tui-cell-val">1.0K HP</span>
              <span class="hero__tui-cell-val t-dim">1.8M VESTS</span>
            </div>
          </div>
        </div>
      </div>

      <!-- witness-001 -->
      <div class="hero__tui-card hero__tui-card--watched">
        <div class="hero__tui-card-top">
          <div class="hero__tui-card-badge">
            <div class="hero__tui-badge hero__tui-badge--watched">witness-001 <span class="hero__tui-close-btn">X</span></div>
