---
import Button from "../ui/Button.astro";
import TerminalFrame from "../ui/TerminalFrame.astro";
import TypewriterText from "../islands/TypewriterText.tsx";
import WorkflowTabs from "../islands/WorkflowTabs.tsx";
import { LINKS } from "../../config/links";

const GITLAB_URL = LINKS.GITLAB;

/* ------------------------------------------------------------------ *
 * TUI visualization — realistic Clive Dashboard                      *
 * Mirrors the real Textual-based TUI: header bar, dashboard panel    *
 * with account balances, RC/voting info, and bottom key hints.       *
 * ------------------------------------------------------------------ */
const heroTuiHtml = `<div class="hero__tui">
  <header class="hero__tui-header">
    <span class="hero__tui-header-left">
      <span class="hero__tui-tab hero__tui-tab--active">alice</span>
      <span class="hero__tui-indicator hero__tui-indicator--ok" aria-hidden="true"></span>
      <span class="hero__tui-lock t-emerald">&#x1f513; UNLOCKED</span>
    </span>
    <span class="hero__tui-header-center">
      <span class="hero__tui-tab hero__tui-tab--selected">Dashboard</span>
      <span class="hero__tui-tab">Cart <span class="t-dim">(empty)</span></span>
    </span>
    <span class="hero__tui-header-right">
      <span class="hero__tui-indicator hero__tui-indicator--ok" aria-hidden="true"></span>
      <span class="t-emerald">online</span>
    </span>
  </header>

  <div class="hero__tui-body">
    <div class="hero__tui-section">
      <div class="hero__tui-section-title">WORKING ACCOUNT</div>
      <div class="hero__tui-account-name">
        <span class="hero__tui-badge hero__tui-badge--ok">alice</span>
        <span class="hero__tui-stats">
          <span class="hero__tui-bar"><span class="hero__tui-bar-label t-dim">RC</span><span class="hero__tui-bar-track"><span class="hero__tui-bar-fill" style="width:98%"></span></span><span class="t-emerald">98%</span></span>
          <span class="hero__tui-bar"><span class="hero__tui-bar-label t-dim">VP</span><span class="hero__tui-bar-track"><span class="hero__tui-bar-fill" style="width:100%"></span></span><span class="t-emerald">100%</span></span>
          <span class="hero__tui-bar"><span class="hero__tui-bar-label t-dim">DP</span><span class="hero__tui-bar-track"><span class="hero__tui-bar-fill hero__tui-bar-fill--full" style="width:100%"></span></span><span class="t-emerald">100%</span></span>
        </span>
      </div>
    </div>

    <div class="hero__tui-section">
      <div class="hero__tui-section-title t-accent">BALANCES</div>
      <div class="hero__tui-table">
        <div class="hero__tui-row hero__tui-row--header">
          <span class="hero__tui-cell-label"></span>
          <span class="hero__tui-cell-val t-dim">HIVE</span>
          <span class="hero__tui-cell-val t-dim">HBD</span>
        </div>
        <div class="hero__tui-row">
          <span class="hero__tui-cell-label t-accent">LIQUID</span>
          <span class="hero__tui-cell-val t-emerald">100,000.000</span>
          <span class="hero__tui-cell-val t-emerald">100,000.000</span>
        </div>
        <div class="hero__tui-row">
          <span class="hero__tui-cell-label t-accent">SAVINGS</span>
          <span class="hero__tui-cell-val">100.000</span>
          <span class="hero__tui-cell-val">190.000</span>
        </div>
        <div class="hero__tui-row">
          <span class="hero__tui-cell-label t-accent">STAKE</span>
          <span class="hero__tui-cell-val">100.0K HP</span>
          <span class="hero__tui-cell-val t-dim">180.0M VESTS</span>
        </div>
      </div>
    </div>

    <div class="hero__tui-section hero__tui-section--watched">
      <div class="hero__tui-section-title t-dim">WATCHED ACCOUNTS</div>
      <div class="hero__tui-account-name">
        <span class="hero__tui-badge hero__tui-badge--warn">bob</span>
        <span class="hero__tui-stats">
          <span class="t-amber">1 ALARM</span>
        </span>
      </div>
      <div class="hero__tui-row hero__tui-row--compact">
        <span class="hero__tui-cell-label t-accent">LIQUID</span>
        <span class="hero__tui-cell-val">1,000.000 HIVE</span>
        <span class="hero__tui-cell-val">1,000.000 HBD</span>
      </div>
    </div>
  </div>

  <footer class="hero__tui-footer">
    <span><span class="hero__tui-key">esc</span> Back</span>
    <span><span class="hero__tui-key">^d</span> Dashboard</span>
    <span><span class="hero__tui-key">^l</span> Lock</span>
    <span><span class="hero__tui-key">^s</span> Settings</span>
    <span><span class="hero__tui-key">?</span> Help</span>
  </footer>
</div>`;

/* ------------------------------------------------------------------ *
 * CLI visualization — realistic Clive CLI session                    *
 * Shows `clive show account` with rich-formatted tables.             *
 * ------------------------------------------------------------------ */
const heroCliHtml = `<span class="t-dim">clive@cli:~/.clive$</span> clive show account alice

<span class="t-cyan">  Details of</span> <span class="t-emerald">'alice'</span> <span class="t-cyan">account</span>

<span class="t-dim">  ┌─────────────────────────────────────────────────┐</span>
<span class="t-dim">  │</span>  <span class="t-yellow">General info</span>                                   <span class="t-dim">│</span>
<span class="t-dim">  ├──────────────┬──────────────────────────────────┤</span>
<span class="t-dim">  │</span> <span class="t-cyan">Name</span>         <span class="t-dim">│</span>  <span class="t-emerald">alice</span>                           <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">Created</span>      <span class="t-dim">│</span>  2019-06-01T12:00:00            <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">Reputation</span>   <span class="t-dim">│</span>  <span class="t-emerald">75</span>                              <span class="t-dim">│</span>
<span class="t-dim">  └──────────────┴──────────────────────────────────┘</span>

<span class="t-dim">  ┌─────────────────────────────────────────────────┐</span>
<span class="t-dim">  │</span>  <span class="t-yellow">The balances</span>                                   <span class="t-dim">│</span>
<span class="t-dim">  ├──────────┬──────────────────┬───────────────────┤</span>
<span class="t-dim">  │</span> <span class="t-emerald">Liquid</span>   <span class="t-dim">│</span> 100,000.000 HIVE <span class="t-dim">│</span> 100,000.000 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Savings</span>  <span class="t-dim">│</span>     100.000 HIVE <span class="t-dim">│</span>     190.000 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Stake</span>    <span class="t-dim">│</span>     100.0K HP   <span class="t-dim">│</span>   180.0M VESTS   <span class="t-dim">│</span>
<span class="t-dim">  └──────────┴──────────────────┴───────────────────┘</span>

<span class="t-dim">  ┌─────────────────────────────────────────────────┐</span>
<span class="t-dim">  │</span>  <span class="t-yellow">Voting info</span>                                    <span class="t-dim">│</span>
<span class="t-dim">  ├──────────────┬──────────────────────────────────┤</span>
<span class="t-dim">  │</span> <span class="t-cyan">Voting power</span> <span class="t-dim">│</span>  <span class="t-emerald">100.00 %</span>                       <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">Downvote</span>     <span class="t-dim">│</span>  <span class="t-emerald">100.00 %</span>                       <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">RC</span>           <span class="t-dim">│</span>  <span class="t-emerald">98.42 %</span>                        <span class="t-dim">│</span>
<span class="t-dim">  └──────────────┴──────────────────────────────────┘</span>

<span class="t-dim">clive@cli:~/.clive$</span> <span class="t-cursor" aria-hidden="true">▌</span>`;
---

<section
  id="hero"
  class="hero"
  aria-labelledby="hero-heading"
>
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container-x hero__inner">
    <div class="hero__content">
      <div class="reveal reveal--delay-1 hero__meta">
        <span class="hero__eyebrow"><span aria-hidden="true">$ </span>clive --help</span>
      </div>

      <h1
        id="hero-heading"
        class="h-display reveal reveal--delay-2 hero__heading"
      >
        <TypewriterText
          client:visible
          text="clive — power-user wallet for "
          accentText="hive"
          speed={50}
          delay={400}
        />
      </h1>

      <p class="reveal reveal--delay-3 hero__subhead">
        Encrypted keys, mouse-driven TUI, full blockchain operations — straight
        from your terminal.
      </p>

      <div class="reveal reveal--delay-4 hero__ctas">
        <Button variant="primary" size="lg" href="#install">
          Get Clive
          <span slot="icon-end" aria-hidden="true">→</span>
        </Button>
        <Button
          variant="secondary"
          size="lg"
          href={GITLAB_URL}
          rel="noopener noreferrer"
          target="_blank"
        >
          View on GitLab
          <span slot="icon-end" aria-hidden="true">↗</span>
        </Button>
      </div>

      <p class="reveal reveal--delay-4 hero__note">
        Open source · Built for Hive
      </p>
    </div>

    <div class="hero__visual reveal reveal--delay-3">
      {/* TUI panel — structured HTML layout */}
      <div class="hero__panel hero__panel--tui">
        <TerminalFrame
          title="clive — dashboard"
          ariaLabel="Clive TUI dashboard preview"
          as="div"
        >
          <WorkflowTabs
            client:visible
            panelId="hero"
            tuiHtml={heroTuiHtml}
            cliHtml={heroCliHtml}
          />
        </TerminalFrame>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-block: var(--section-y);
    overflow: hidden;
  }
  @media (min-width: 64rem) {
    .hero {
      padding-block: var(--section-y-lg);
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--hero-gradient);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 32rem;
    min-width: 0;
  }

  .hero__meta {
    display: inline-block;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .hero__heading {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.625rem, 4.6vw, 3.5rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
  }
  /* Typewriter island — grid-stack technique for zero CLS
   * SSR: sizer visible (full text + cursor), overlay hidden
   * After hydration: sizer hidden, overlay active with typing animation */
  .hero__heading :global(.typewriter) {
    display: inline-grid;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero__heading :global(.typewriter__sizer),
  .hero__heading :global(.typewriter__overlay) {
    grid-area: 1 / 1;
  }

  /* Sizer: visible on SSR, hidden after JS hydration */
  .hero__heading :global(.typewriter__sizer) {
    /* visible by default — SSR shows full text */
  }
  .hero__heading :global(.typewriter__sizer--hidden) {
    visibility: hidden;
  }

  /* Overlay: hidden on SSR, visible after JS hydration */
  .hero__heading :global(.typewriter__overlay) {
    visibility: hidden;
  }
  .hero__heading :global(.typewriter__overlay--active) {
    visibility: visible;
  }

  .hero__heading :global(.typewriter__accent) {
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor) {
    display: inline-block;
    margin-left: 0.02em;
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor--blink) {
    animation: clive-cursor-blink var(--cursor-blink-duration) steps(2, end) infinite;
  }
  @keyframes clive-cursor-blink {
    0%, 49.99% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__heading :global(.typewriter__cursor--blink) {
      animation: none;
      opacity: 1;
    }
  }

  .hero__subhead {
    font-size: clamp(1rem, 1.1rem + 0.2vw, 1.25rem);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .hero__visual {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .hero__panel {
    /* wrapper for the terminal frame inside hero__visual */
  }

  /* ============================================================
   * Mode-root — transition wrapper from WorkflowTabs
   * ============================================================ */
  :global(.workflow-tabs__mode-root) {
    transition: background-color 300ms ease, border-color 300ms ease;
  }

  /* ============================================================
   * TUI Dashboard — structured multi-panel layout
   * ============================================================ */
  :global(.hero__tui) {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: clamp(0.625rem, 0.5rem + 0.45vw, 0.8125rem);
    line-height: 1.3;
    color: var(--mode-text, var(--color-text));
    gap: 0;
    background-color: var(--mode-bg, var(--color-bg-surface));
    border-radius: var(--radius-md);
    transition: background-color 300ms ease, color 300ms ease;
  }

  /* Header bar — top status line */
  :global(.hero__tui-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-1) var(--space-2);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    font-size: 0.6875em;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    transition: background-color 300ms ease, border-color 300ms ease;
  }
  :global(.hero__tui-header-left),
  :global(.hero__tui-header-center),
  :global(.hero__tui-header-right) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }
  :global(.hero__tui-header-center) {
    display: flex;
    gap: 0;
  }

  /* Tab-style navigation in header */
  :global(.hero__tui-tab) {
    padding: 0.125rem 0.5rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    font-size: 0.875em;
  }
  :global(.hero__tui-tab--active) {
    color: var(--mode-accent-primary, var(--color-primary-bright));
    font-weight: var(--font-weight-semibold);
  }
  :global(.hero__tui-tab--selected) {
    background-color: var(--mode-border, rgba(96, 165, 250, 0.15));
    border-radius: var(--radius-xs);
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }

  /* Status indicators */
  :global(.hero__tui-indicator) {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }
  :global(.hero__tui-indicator--ok) {
    background-color: var(--mode-accent-success, var(--color-accent-success));
    box-shadow: 0 0 4px var(--mode-accent-success, var(--color-accent-success));
  }

  /* Lock status */
  :global(.hero__tui-lock) {
    font-weight: var(--font-weight-semibold);
    font-size: 0.875em;
  }

  /* Body — account sections */
  :global(.hero__tui-body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-2);
  }

  /* Section blocks */
  :global(.hero__tui-section) {
    border: 1px solid var(--mode-border-active, var(--color-border-default));
    border-radius: var(--radius-xs);
    padding: var(--space-1) var(--space-2);
    transition: border-color 300ms ease;
  }
  :global(.hero__tui-section--watched) {
    border-color: var(--mode-border, color-mix(in srgb, var(--color-border-bright) 20%, transparent));
  }
  :global(.hero__tui-section-title) {
    font-size: 0.6875em;
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--mode-text-muted, var(--color-text-muted));
    margin-bottom: var(--space-1);
  }

  /* Account name + badge */
  :global(.hero__tui-account-name) {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    margin-bottom: var(--space-1);
  }
  :global(.hero__tui-badge) {
    display: inline-block;
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius-xs);
    font-weight: var(--font-weight-semibold);
    font-size: 0.8125em;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  :global(.hero__tui-badge--ok) {
    background-color: var(--mode-accent-success, var(--color-primary));
    color: #fff;
  }
  :global(.hero__tui-badge--warn) {
    background-color: var(--mode-accent-danger, var(--color-accent-danger));
    color: #fff;
  }

  /* Stats — now vertical with progress bars */
  :global(.hero__tui-stats) {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    flex: 1;
    min-width: 0;
  }

  /* Progress bars */
  :global(.hero__tui-bar) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75em;
  }
  :global(.hero__tui-bar-label) {
    width: 1.5rem;
    text-align: right;
    flex-shrink: 0;
    font-size: 0.875em;
  }
  :global(.hero__tui-bar-track) {
    flex: 1;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
    min-width: 2rem;
  }
  :global(.hero__tui-bar-fill) {
    height: 100%;
    background-color: var(--mode-accent-success, var(--color-accent-success));
    border-radius: 2px;
    transition: width 600ms var(--ease-out-quint);
  }
  :global(.hero__tui-bar-fill--full) {
    background-color: var(--mode-accent-primary, var(--color-primary-bright));
  }

  /* Balance table rows */
  :global(.hero__tui-table) {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  :global(.hero__tui-row) {
    display: grid;
    grid-template-columns: 5rem 1fr 1fr;
    gap: var(--space-1);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--mode-border, color-mix(in srgb, var(--color-border-bright) 15%, transparent));
    transition: border-color 300ms ease;
  }
  :global(.hero__tui-row--header) {
    border-bottom: 1px solid var(--mode-border-active, color-mix(in srgb, var(--color-border-bright) 30%, transparent));
    padding-bottom: 0.25rem;
  }
  :global(.hero__tui-row:last-child) {
    border-bottom: none;
  }
  :global(.hero__tui-row--compact) {
    padding: 0.125rem 0;
    border-bottom: none;
    margin-top: var(--space-1);
  }
  :global(.hero__tui-cell-label) {
    font-weight: var(--font-weight-semibold);
    font-size: 0.8125em;
    text-align: center;
    padding: 0.0625rem 0.25rem;
    background-color: color-mix(in srgb, var(--mode-accent-primary, var(--color-primary)) 15%, transparent);
    border-radius: var(--radius-xs);
    transition: background-color 300ms ease;
  }
  :global(.hero__tui-cell-val) {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Footer — key hints */
  :global(.hero__tui-footer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-1) var(--space-2);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-top: 1px solid var(--mode-border, var(--color-border-default));
    font-size: 0.625em;
    color: var(--mode-text-muted, var(--color-text-muted));
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: background-color 300ms ease, border-color 300ms ease;
  }

  /* Keyboard shortcut key styling */
  :global(.hero__tui-key) {
    display: inline-block;
    padding: 0 0.25rem;
    background-color: rgba(255, 166, 43, 0.15);
    border: 1px solid rgba(255, 166, 43, 0.30);
    border-radius: 2px;
    color: var(--color-accent-warning);
    font-size: 0.9em;
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    margin-right: 0.125rem;
  }

  /* Mobile: hide less important elements */
  @media (max-width: 25rem) {
    :global(.hero__tui-header-right) {
      display: none;
    }
    :global(.hero__tui-section--watched) {
      display: none;
    }
    :global(.hero__tui-row) {
      grid-template-columns: 4rem 1fr;
    }
    :global(.hero__tui-cell-val:last-child) {
      display: none;
    }
