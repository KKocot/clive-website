              <div class="hero__tui-mana-pct">100.00 % <span class="hero__tui-mana-type">RC</span></div>
              <div class="hero__tui-mana-detail">10.0K HP <span class="t-emerald">Full!</span></div>
            </div>
            <div class="hero__tui-mana-col" style="--bar-fill:100%">
              <div class="hero__tui-mana-pct">100.00 % <span class="hero__tui-mana-type">VOTING</span></div>
              <div class="hero__tui-mana-detail">10.0K HP <span class="t-emerald">Full!</span></div>
            </div>
            <div class="hero__tui-mana-col" style="--bar-fill:100%">
              <div class="hero__tui-mana-pct">100.00 % <span class="hero__tui-mana-type">DOWNVOTING</span></div>
              <div class="hero__tui-mana-detail">2.5K HP <span class="t-emerald">Full!</span></div>
            </div>
          </div>
        </div>
        <div class="hero__tui-card-bottom">
          <div class="hero__tui-last">
            <div class="hero__tui-last-label">LAST:</div>
            <div class="hero__tui-last-row"><span class="t-dim">History entry:</span> 2026-02-11T13:54:39</div>
            <div class="hero__tui-last-row"><span class="t-dim">Account update:</span> never</div>
          </div>
          <div class="hero__tui-table">
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">LIQUID</span>
              <span class="hero__tui-cell-val">10000.000 HIVE</span>
              <span class="hero__tui-cell-val">9990.000 HBD</span>
            </div>
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">SAVINGS</span>
              <span class="hero__tui-cell-val">0.000 HIVE</span>
              <span class="hero__tui-cell-val">0.000 HBD</span>
            </div>
            <div class="hero__tui-row">
              <span class="hero__tui-cell-label hero__tui-label">STAKE</span>
              <span class="hero__tui-cell-val">10.0K HP</span>
              <span class="hero__tui-cell-val t-dim">18.0M VESTS</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="hero__tui-footer">
    <span><span class="hero__tui-key">?</span> Help</span>
    <span><span class="hero__tui-key">d</span> Account details</span>
    <span><span class="hero__tui-key">r</span> Remove</span>
    <span><span class="hero__tui-key">o</span> Operations</span>
    <span><span class="hero__tui-key">w</span> Switch account</span>
    <span><span class="hero__tui-key">a</span> Add account</span>
    <span><span class="hero__tui-key">^l</span> Lock</span>
    <span><span class="hero__tui-key">^s</span></span>
    <span><span class="hero__tui-key">^p</span> palette</span>
  </footer>
</div>`;

/* ------------------------------------------------------------------ *
 * CLI visualization — realistic Clive CLI session                    *
 * Shows `clive show account` with rich-formatted tables.             *
 * ------------------------------------------------------------------ */
const heroCliHtml = `<span class="t-dim">clive@cli:~$</span> clive show account alice
<span class="t-dim">Using beekeeper at</span> <span class="t-accent">http://127.0.0.1:39507</span>

<span class="t-cyan"> Details of</span> <span class="t-emerald">'alice'</span> <span class="t-cyan">account</span>

<span class="t-dim"> ┌────────────────────────────────────────────────────┐
 │</span> <span class="t-yellow">General info</span>                                       <span class="t-dim">│
 ├──────────────────────┬─────────────────────────────┤
 │</span> <span class="t-emerald">Account type</span>         <span class="t-dim">│</span> <span class="t-emerald">Tracked account (working)</span>   <span class="t-dim">│
 │</span> <span class="t-emerald">Last history entry</span>   <span class="t-dim">│</span> 2026-02-11T13:54:45         <span class="t-dim">│
 │</span> <span class="t-emerald">Account update</span>       <span class="t-dim">│</span> never                       <span class="t-dim">│
 │</span> <span class="t-emerald">New account tokens</span>   <span class="t-dim">│</span> 0                           <span class="t-dim">│
 │</span> <span class="t-emerald">Number of alarms</span>     <span class="t-dim">│</span> 0                           <span class="t-dim">│
 │</span> <span class="t-emerald">Recovery account</span>     <span class="t-dim">│</span> steem                       <span class="t-dim">│
 └──────────────────────┴─────────────────────────────┘</span>

<span class="t-dim"> ┌────────────────────────────────────────────────────┐
 │</span> <span class="t-comment">The balances</span>                                       <span class="t-dim">│
 ├─────────┬───────────────────┬──────────────────────┤
 │</span> <span class="t-emerald">Liquid</span>  <span class="t-dim">│</span> 100,000.000 HIVE  <span class="t-dim">│</span> 100,000.000 HBD      <span class="t-dim">│
 │</span> <span class="t-emerald">Savings</span> <span class="t-dim">│</span>     100.000 HIVE  <span class="t-dim">│</span>     190.000 HBD      <span class="t-dim">│
 │</span> <span class="t-emerald">Stake</span>   <span class="t-dim">│</span>     100.0K HP     <span class="t-dim">│</span>   180.0M VESTS       <span class="t-dim">│
 └─────────┴───────────────────┴──────────────────────┘</span>

<span class="t-dim"> ┌────────────────────────────────────────────────────┐
 │</span> <span class="t-yellow">Voting info</span>                                        <span class="t-dim">│
 ├──────────────────────┬────────┬────────┬───────────┤
 │</span>                      <span class="t-dim">│</span> <span class="t-cyan">RC</span>     <span class="t-dim">│</span> <span class="t-cyan">Voting</span> <span class="t-dim">│</span> <span class="t-cyan">Downvote</span>  <span class="t-dim">│
 ├──────────────────────┼────────┼────────┼───────────┤
 │</span> <span class="t-emerald">Percent</span>              <span class="t-dim">│</span> <span class="t-cyan">100.0%</span> <span class="t-dim">│</span> <span class="t-cyan">100.0%</span> <span class="t-dim">│</span> <span class="t-cyan">100.0%</span>    <span class="t-dim">│
 │</span> <span class="t-emerald">Current mana</span>         <span class="t-dim">│</span> <span class="t-cyan">180.3B</span> <span class="t-dim">│</span> <span class="t-cyan">180.3B</span> <span class="t-dim">│</span> <span class="t-cyan">45.1B</span>     <span class="t-dim">│
 │</span> <span class="t-emerald">Time to full</span>         <span class="t-dim">│</span> <span class="t-cyan">Full!</span>  <span class="t-dim">│</span> <span class="t-cyan">Full!</span>  <span class="t-dim">│</span> <span class="t-cyan">Full!</span>     <span class="t-dim">│
 └──────────────────────┴────────┴────────┴───────────┘</span>

<span class="t-dim">clive@cli:~$</span> <span class="t-cursor" aria-hidden="true">▌</span>`;
---

<section
  id="hero"
  class="hero"
  aria-labelledby="hero-heading"
>
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container-x hero__inner">
    <div class="hero__content">
      <div class="reveal reveal--delay-1 hero__meta">
        <span class="hero__eyebrow"><span aria-hidden="true">$ </span>clive --help</span>
      </div>

      <h1
        id="hero-heading"
        class="h-display reveal reveal--delay-2 hero__heading"
      >
        <TypewriterText
          client:visible
          text="clive — power-user wallet for "
          accentText="hive"
          speed={50}
          delay={400}
        />
      </h1>

      <p class="reveal reveal--delay-3 hero__subhead">
        Encrypted keys, mouse-driven TUI, full blockchain operations — straight
        from your terminal.
      </p>

      <div class="reveal reveal--delay-4 hero__ctas">
        <Button variant="primary" size="lg" href="#install">
          Get Clive
          <span slot="icon-end" aria-hidden="true">→</span>
        </Button>
        <Button
          variant="secondary"
          size="lg"
          href={GITLAB_URL}
          rel="noopener noreferrer"
          target="_blank"
        >
          View on GitLab
          <span slot="icon-end" aria-hidden="true">↗</span>
        </Button>
      </div>

      <p class="reveal reveal--delay-4 hero__note">
        Open source · Built for Hive
      </p>
    </div>

    <div class="hero__visual reveal reveal--delay-3">
      {/* TUI panel — structured HTML layout */}
      <div class="hero__panel hero__panel--tui">
        <TerminalFrame
          title="clive — dashboard"
          ariaLabel="Clive TUI dashboard preview"
          as="div"
        >
          <WorkflowTabs
            client:visible
            panelId="hero"
            tuiHtml={heroTuiHtml}
            cliHtml={heroCliHtml}
          />
        </TerminalFrame>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-block: var(--section-y);
    overflow: hidden;
  }
  @media (min-width: 64rem) {
    .hero {
      padding-block: var(--section-y-lg);
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--hero-gradient);
    pointer-events: none;
    transition: background var(--mode-transition, 300ms) ease;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 32rem;
    min-width: 0;
  }

  .hero__meta {
    display: inline-block;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .hero__heading {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.625rem, 4.6vw, 3.5rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
  }
  /* Typewriter island — grid-stack technique for zero CLS
   * SSR: sizer visible (full text + cursor), overlay hidden
   * After hydration: sizer hidden, overlay active with typing animation */
  .hero__heading :global(.typewriter) {
    display: inline-grid;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero__heading :global(.typewriter__sizer),
  .hero__heading :global(.typewriter__overlay) {
    grid-area: 1 / 1;
  }

  /* Sizer: visible on SSR, hidden after JS hydration */
  .hero__heading :global(.typewriter__sizer) {
    /* visible by default — SSR shows full text */
  }
  .hero__heading :global(.typewriter__sizer--hidden) {
    visibility: hidden;
  }

  /* Overlay: hidden on SSR, visible after JS hydration */
  .hero__heading :global(.typewriter__overlay) {
    visibility: hidden;
  }
  .hero__heading :global(.typewriter__overlay--active) {
    visibility: visible;
  }

  .hero__heading :global(.typewriter__accent) {
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor) {
    display: inline-block;
    margin-left: 0.02em;
    color: var(--color-primary-bright);
  }
  .hero__heading :global(.typewriter__cursor--blink) {
    animation: clive-cursor-blink var(--cursor-blink-duration) steps(2, end) infinite;
  }
  @keyframes clive-cursor-blink {
    0%, 49.99% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__heading :global(.typewriter__cursor--blink) {
      animation: none;
      opacity: 1;
    }
  }

  .hero__subhead {
    font-size: clamp(1rem, 1.1rem + 0.2vw, 1.25rem);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .hero__visual {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .hero__panel {
    /* wrapper for the terminal frame inside hero__visual */
  }

  /* ============================================================
   * Mode-root — transition wrapper from WorkflowTabs
   * ============================================================ */
  :global(.workflow-tabs__mode-root) {
    transition: background-color 300ms ease, border-color 300ms ease;
  }

  /* ============================================================
   * TUI Dashboard — card-based account layout
   * Each account is a self-contained card with badge, resource
   * bars, LAST info, and balance table.
   * ============================================================ */
  :global(.hero__tui) {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: clamp(0.625rem, 0.5rem + 0.45vw, 0.8125rem);
    line-height: 1.3;
    color: var(--mode-text, var(--color-text));
    gap: 0;
    background-color: var(--mode-bg, var(--color-bg-surface));
    border-radius: var(--radius-md);
    transition: background-color 300ms ease, color 300ms ease;
  }

  /* Header bar — top status line */
  :global(.hero__tui-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-1) var(--space-2);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    font-size: 0.6875em;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    transition: background-color 300ms ease, border-color 300ms ease;
  }
  :global(.hero__tui-header-left),
  :global(.hero__tui-header-center),
  :global(.hero__tui-header-right) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }
  :global(.hero__tui-header-center) {
    display: flex;
    gap: 0;
  }

  /* Tab-style navigation in header */
  :global(.hero__tui-tab) {
    padding: 0.125rem 0.5rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    font-size: 0.875em;
  }
  :global(.hero__tui-tab--selected) {
    background-color: var(--mode-border, rgba(96, 165, 250, 0.15));
    border-radius: var(--radius-xs);
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }

  /* Status indicators */
  :global(.hero__tui-indicator) {
    display: inline-block;
