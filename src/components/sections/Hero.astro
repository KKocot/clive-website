            <span class="hero__tui-cell-val">100000.000 HIVE</span>
            <span class="hero__tui-cell-val">100000.000 HBD</span>
          </div>
          <div class="hero__tui-row">
            <span class="hero__tui-cell-label hero__tui-label">SAVINGS</span>
            <span class="hero__tui-cell-val">100.000 HIVE</span>
            <span class="hero__tui-cell-val">190.000 HBD</span>
          </div>
          <div class="hero__tui-row">
            <span class="hero__tui-cell-label hero__tui-label">STAKE</span>
