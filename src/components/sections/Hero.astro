        </div>
      </div>
    </div>

    <!-- ====== WATCHED ACCOUNTS ====== -->
    <div class="hero__tui-section hero__tui-section--watched">
      <div class="hero__tui-section-title t-dim">WATCHED ACCOUNTS</div>

      <!-- bob -->
      <div class="hero__tui-card hero__tui-card--watched">
        <div class="hero__tui-card-top">
          <div class="hero__tui-card-badge">
            <div class="hero__tui-badge hero__tui-badge--watched">bob <span class="hero__tui-close-btn">X</span></div>
