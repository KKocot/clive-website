---
import { LINKS } from "../../config/links";

const currentYear = new Date().getFullYear();
const VERSION = "v1.28.8.1";
---

<footer class="footer">
  <div class="container-x footer__bar">
    <p class="footer__copy">© {currentYear} clive contributors</p>
    <div class="footer__meta">
      <a
        href={LINKS.MIT_LICENSE}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__license-link"
        aria-label="MIT license — opens in new tab"
      ><span aria-hidden="true">[</span>MIT<span aria-hidden="true">]</span></a>
      <span aria-hidden="true" class="footer__sep">·</span>
      <span class="footer__version tag-bracket"
        ><span aria-hidden="true">[</span>{VERSION}<span aria-hidden="true">]</span></span>
      <span aria-hidden="true" class="footer__sep">·</span>
      <a
        href={LINKS.HIVE}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__hive-link"
        aria-label="Hive blockchain — opens in new tab"
      >
        <span aria-hidden="true">// </span>built for <span class="footer__hive-mark">hive</span> blockchain
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background-color: #0d0d0d;
    padding-block: var(--space-4);
  }
  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(1, 120, 212, 0.5),
      transparent
    );
    pointer-events: none;
  }

  .footer__bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3) var(--space-4);
  }

  .footer__copy {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
  }

  .footer__meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .footer__license-link {
    font-family: var(--font-mono);
    font-size: inherit;
    color: var(--color-text-subtle);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quad);
  }
  .footer__license-link:hover {
    color: var(--color-primary-bright);
  }

  .footer__sep {
    color: var(--color-text-subtle);
  }

  .footer__version {
    font-family: var(--font-mono);
    color: var(--color-text-subtle);
  }

  .footer__hive-link {
    font-family: var(--font-mono);
    color: var(--color-text-subtle);
    text-decoration: none;
    text-transform: lowercase;
    transition: color var(--duration-fast) var(--ease-out-quad);
  }
  .footer__hive-link:hover {
    color: var(--color-hive-text);
  }
  .footer__hive-mark {
    color: var(--color-hive-text);
    font-weight: var(--font-weight-semibold);
  }

  @media (max-width: 40rem) {
    .footer__bar {
      justify-content: center;
      text-align: center;
    }
    .footer__meta {
      justify-content: center;
    }
  }
</style>
