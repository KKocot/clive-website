---
import { LINKS } from "../../config/links";

const currentYear = new Date().getFullYear();
const VERSION = "v1.28.8.1";
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href={LINKS.GITLAB_RELEASES}
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Clive ${VERSION} — releases on GitLab`}
        >[clive {VERSION}]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__segment"
      >© {currentYear}</span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.MIT_LICENSE}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.HIVE}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive blockchain ecosystem — opens in new tab"
      >built for <span class="tmux-status__hive">hive</span></a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__dot"
      aria-label="Status: online">●</span
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--tui-panel-border-color);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: var(--space-2) var(--space-4);
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-subtle);
    padding-inline: var(--space-2);
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out-quad);
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-primary-bright);
    text-shadow: var(--glow-intensity) var(--glow-color);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }

  .tmux-status__hive {
    color: var(--color-hive-text);
    font-weight: var(--font-weight-semibold);
  }

  .tmux-status__dot {
    color: var(--color-accent-success);
    font-size: 0.625rem;
    line-height: 1;
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      padding: var(--space-2) var(--space-3);
      justify-content: center;
    }
  }
</style>
