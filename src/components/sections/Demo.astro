---
import TerminalFrame from "../ui/TerminalFrame.astro";
import TuiPanel from "../ui/TuiPanel.astro";
import InstallModeSwitch from "../islands/InstallModeSwitch.tsx";
import WorkflowTabs from "../islands/WorkflowTabs.tsx";

/* ------------------------------------------------------------------ *
 * TUI visualization — Transfer scenario                              *
 * Two-panel layout: sidebar with menu + transfer form view            *
 * Matches section description: "unlock wallet, sign transfer, broadcast" *
 * ------------------------------------------------------------------ */
const demoTuiHtml = `<div class="demo-tui">
  <div class="demo-tui__panels">
    <section class="demo-tui__panel" aria-label="clive sidebar">
      <header class="demo-tui__panel-title">clive</header>
      <div class="demo-tui__panel-body">
        <ul class="demo-tui__menu" role="list">
          <li>Dashboard</li>
          <li class="is-active"><span class="t-accent">&gt; Transfer</span></li>
          <li>Governance</li>
          <li>Power</li>
          <li>Savings</li>
        </ul>
        <hr class="demo-tui__sep" />
        <p class="demo-tui__label t-dim">profile</p>
        <p class="demo-tui__value"><span class="t-emerald">@alice</span></p>
        <p class="demo-tui__label t-dim">balance</p>
        <p class="demo-tui__value">1,234.567 <span class="t-emerald">HIVE</span></p>
      </div>
      <footer class="demo-tui__panel-foot">
        <span class="t-dim">node</span>
        <span>api.hive.blog</span>
        <span class="t-emerald" aria-hidden="true">&bull;</span>
      </footer>
    </section>

    <section class="demo-tui__panel" aria-label="transfer form">
      <header class="demo-tui__panel-title">transfer &middot; new operation</header>
      <div class="demo-tui__panel-body">
        <div class="demo-tui__field">
          <span class="demo-tui__label t-dim">from</span>
          <span class="demo-tui__input"><span class="t-emerald">@alice</span></span>
        </div>
        <div class="demo-tui__field">
          <span class="demo-tui__label t-dim">to</span>
          <span class="demo-tui__input"><span class="t-accent">@bob</span></span>
        </div>
        <div class="demo-tui__field">
          <span class="demo-tui__label t-dim">amount</span>
          <span class="demo-tui__input">25.000 <span class="t-emerald">HIVE</span></span>
        </div>
        <div class="demo-tui__field">
          <span class="demo-tui__label t-dim">memo</span>
          <span class="demo-tui__input t-subtle">payment for services</span>
        </div>
        <hr class="demo-tui__sep" />
        <div class="demo-tui__action">
          <span class="demo-tui__btn t-accent">[ Add to cart ]</span>
        </div>
      </div>
      <footer class="demo-tui__panel-foot">
        <span class="t-dim">cart</span>
        <span class="t-amber">1 op</span>
        <span class="demo-tui__sep-dot" aria-hidden="true">&middot;</span>
        <span class="t-dim">unlocked</span>
        <span class="t-emerald" aria-hidden="true">&bull;</span>
        <span class="demo-tui__sep-dot" aria-hidden="true">&middot;</span>
        <span class="t-dim">14:32</span>
      </footer>
    </section>
  </div>

  <p class="demo-tui__keys">
    <span><span class="t-amber">F1</span> <span class="t-dim">help</span></span>
    <span><span class="t-amber">F2</span> <span class="t-dim">menu</span></span>
    <span><span class="t-amber">F5</span> <span class="t-dim">refresh</span></span>
    <span><span class="t-amber">F10</span> <span class="t-dim">quit</span></span>
  </p>
</div>`;

/* ------------------------------------------------------------------ *
 * CLI visualization — same transfer scenario in CLI mode              *
 * ------------------------------------------------------------------ */
const demoCliHtml = `<span class="t-dim">clive@cli:~$</span> clive process transfer \\
  --from alice --to bob --amount <span class="t-accent">"25.000 HIVE"</span>

<span class="t-subtle">  Preparing transaction...</span>
<span class="t-dim">  From:</span>    <span class="t-emerald">@alice</span>
<span class="t-dim">  To:</span>      <span class="t-accent">@bob</span>
<span class="t-dim">  Amount:</span>  25.000 HIVE
<span class="t-dim">  Memo:</span>    payment for services

  Broadcast transaction? [<span class="t-emerald">Y</span>/n]: <span class="t-emerald">Y</span>

<span class="t-emerald">  Transaction broadcast successfully.</span>
<span class="t-dim">  Block:</span> 82,451,307  <span class="t-dim">TxID:</span> <span class="t-subtle">a3f9e1...c704</span>

<span class="t-dim">clive@cli:~$</span> clive show balances

<span class="t-subtle">         Details of 'alice' account</span>
<span class="t-accent">              The balances</span>
<span class="t-dim">  ┌──────────┬──────────────────┬──────────────────┐</span>
<span class="t-dim">  │</span> <span class="t-emerald">Liquid</span>   <span class="t-dim">│</span>    1,209.567 HIVE <span class="t-dim">│</span>     89.420 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Savings</span>  <span class="t-dim">│</span>      100.000 HIVE <span class="t-dim">│</span>    190.000 HBD  <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-emerald">Stake</span>    <span class="t-dim">│</span>    4,500.000 HP   <span class="t-dim">│</span>      8.1M VESTS <span class="t-dim">│</span>
<span class="t-dim">  └──────────┴──────────────────┴──────────────────┘</span>

<span class="t-dim">clive@cli:~$</span> <span class="t-cursor" aria-hidden="true">▌</span>`;
---

<TuiPanel title="$ clive --tui" id="demo" class="demo reveal-scroll">
  <div class="container-x">
    <header class="demo__header reveal">
      <p class="demo__eyebrow"><span aria-hidden="true">// </span>see it in action</p>
      <h2 id="demo-heading" class="demo__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>demo
      </h2>
      <p class="demo__lead">A typical session: unlock the wallet, sign a transfer, broadcast.</p>
    </header>

    <div class="demo__frame reveal">
      <InstallModeSwitch
        client:visible
        channel="demo-mode"
        class="demo-mode-switch"
        ariaLabel="Demo preview mode"
      />

      <TerminalFrame title="clive — transfer" ariaLabel="Clive TUI/CLI demo preview" as="div">
        <WorkflowTabs
          client:visible
          channel="demo-mode"
          tuiHtml={demoTuiHtml}
          cliHtml={demoCliHtml}
        />
      </TerminalFrame>
    </div>
  </div>
</TuiPanel>

<style>
  :global(.demo) {
    padding: var(--space-3);
    min-height: calc(100dvh - var(--header-h));
  }

  .demo__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .demo__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .demo__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .demo__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .demo__frame {
    max-width: 60rem;
    margin-inline: auto;
  }

  /* ============================================================
   * Demo mode switch — compact TUI/CLI toggle
   * ============================================================ */
  :global(.demo-mode-switch) {
    display: flex;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
    padding: var(--space-1);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    max-width: 12rem;
  }

  /* ============================================================
   * White-space overrides for WorkflowTabs panels
   * TUI content = normal flow, CLI content = pre-wrapped
   * ============================================================ */
  :global(.demo__frame .workflow-tabs__panel) {
    white-space: normal;
  }

  :global(.demo__frame [id$="-panel-cli"].workflow-tabs__panel) {
    white-space: pre-wrap;
  }

  /* ============================================================
   * TUI panels — CSS borders replacing unicode box-drawing.
   * Lives inside innerHTML, so all selectors must be :global().
   * ============================================================ */
  :global(.demo-tui) {
    white-space: normal;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-text);
    font-feature-settings:
      "calt" 0,
      "liga" 0;
    font-variant-ligatures: none;
    font-variant-numeric: tabular-nums;
  }

  :global(.demo-tui__panels) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  @media (max-width: 40rem) {
    :global(.demo-tui__panels) {
      grid-template-columns: 1fr;
    }
  }

  :global(.demo-tui__panel) {
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    background: transparent;
    display: flex;
    flex-direction: column;
    min-height: 16rem;
  }

  :global(.demo-tui__panel-title) {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border-default);
    letter-spacing: 0.02em;
  }

  :global(.demo-tui__panel-body) {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.demo-tui__panel-body > p) {
    margin: 0;
  }

  :global(.demo-tui__panel-foot) {
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid var(--color-border-default);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
  }

  :global(.demo-tui__sep-dot) {
    color: var(--color-text-subtle);
  }

  :global(.demo-tui__menu) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  :global(.demo-tui__menu li) {
    padding-inline: var(--space-2);
  }

  :global(.demo-tui__sep) {
    border: none;
    border-top: 1px solid var(--color-border-default);
    margin: var(--space-2) 0;
    width: 60%;
  }

  :global(.demo-tui__label) {
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
  }

  :global(.demo-tui__value) {
    margin: 0;
  }

  :global(.demo-tui__keys) {
    margin: var(--space-3) 0 0;
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ============================================================
   * Transfer form fields — right panel
   * ============================================================ */
  :global(.demo-tui__field) {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  :global(.demo-tui__field .demo-tui__label) {
    min-width: 3.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.demo-tui__input) {
    flex: 1;
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border-bright) 30%, transparent);
    font-size: var(--text-sm);
  }

  :global(.demo-tui__action) {
    display: flex;
    justify-content: center;
    padding-top: var(--space-2);
  }

  :global(.demo-tui__btn) {
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
  }

  /* ============================================================
   * Balance table (reused from previous demo, kept for sidebar)
   * ============================================================ */
  :global(.demo-tui__bal),
  :global(.demo-tui__act) {
    width: 100%;
    border-collapse: collapse;
  }

  :global(.demo-tui__bal td),
  :global(.demo-tui__act td) {
    padding: 1px var(--space-3) 1px 0;
    vertical-align: baseline;
  }

  :global(.demo-tui__bal td:nth-child(2)) {
    text-align: right;
  }
</style>
