---
import TerminalFrame from "../ui/TerminalFrame.astro";

const demoTerminalHtml = `╭─ clive ───────────────────────────────────╮ ╭─ wallet · @alice ──────────────────────────╮
│ <span class="t-accent">> Wallet</span>                                  │ │ <span class="t-dim">balance</span>                                    │
│   Accounts                                │ │   <span class="t-emerald">HIVE</span>          1,234.567                  │
│   Transfer                                │ │   <span class="t-emerald">HBD</span>              89.420                  │
│   History                                 │ │   <span class="t-accent">HP</span>           4,500.000                   │
│   Settings                                │ │                                            │
│                                           │ │ <span class="t-dim">last activity</span>                              │
│ <span class="t-dim">───────────────</span>                           │ │   <span class="t-amber">12:04</span>  transfer  -25.000 HIVE            │
│ <span class="t-dim">profile</span>                                   │ │   <span class="t-amber">11:51</span>  vote      witness gtg             │
│   <span class="t-emerald">@alice</span>                                  │ │   <span class="t-amber">10:22</span>  delegate  +500.000 HP             │
│                                           │ │                                            │
│                                           │ │                                            │
├───────────────────────────────────────────┤ ├────────────────────────────────────────────┤
│ <span class="t-dim">node</span>  api.hive.blog  <span class="t-emerald">●</span>                    │ │ <span class="t-dim">cart</span> 0 ops · <span class="t-dim">unlocked</span> <span class="t-emerald">●</span> · <span class="t-dim">14:32</span>            │
╰───────────────────────────────────────────╯ ╰────────────────────────────────────────────╯

<span class="t-amber">F1</span> <span class="t-dim">help</span>  <span class="t-amber">F2</span> <span class="t-dim">menu</span>  <span class="t-amber">F5</span> <span class="t-dim">refresh</span>  <span class="t-amber">F10</span> <span class="t-dim">quit</span>`;
---

<section
  id="demo"
  class="demo"
  aria-labelledby="demo-heading"
>
  <div class="container-x">
    <header class="demo__header reveal">
      <p class="demo__eyebrow"><span aria-hidden="true">// </span>live demo</p>
      <h2 id="demo-heading" class="demo__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>demo
      </h2>
      <p class="demo__lead">
        A typical session: unlock the wallet, sign a transfer, broadcast.
      </p>
    </header>

    <div class="demo__frame reveal">
      {/* TODO: replace with asciinema cast or MP4 demo */}
      <TerminalFrame
        title="clive — main view"
        ariaLabel="Clive TUI demo placeholder"
      >
        <Fragment set:html={demoTerminalHtml} />
      </TerminalFrame>
    </div>

    <p class="demo__caption">
      Demo coming soon · Asciinema cast in preparation
    </p>
  </div>
</section>

<style>
  .demo {
    padding-block: var(--section-y);
  }
  @media (min-width: 64rem) {
    .demo {
      padding-block: var(--section-y-lg);
    }
  }

  .demo__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .demo__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .demo__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .demo__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .demo__frame {
    max-width: 60rem;
    margin-inline: auto;
  }

  .demo__caption {
    margin: var(--space-4) 0 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }
</style>
