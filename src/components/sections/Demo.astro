---
import TerminalFrame from "../ui/TerminalFrame.astro";
import TuiPanel from "../ui/TuiPanel.astro";
import WorkflowTabs from "../islands/WorkflowTabs.tsx";

/* ------------------------------------------------------------------ *
 * TUI visualization — Transfer scenario                              *
 * Real Clive layout: header bar + main content (form) + right panel  *
 * Sourced from actual Clive TUI screenshots (transfer flow)          *
 * ------------------------------------------------------------------ */
const demoTuiHtml = `<div class="demo-tui">
  <header class="demo-tui__topbar">
    <span class="demo-tui__topbar-left">
      <span class="demo-tui__topbar-user">alice / <span class="t-accent">@alice</span></span>
      <span class="demo-tui__topbar-unlock t-emerald">UNLOCKED</span>
    </span>
    <span class="demo-tui__topbar-right">
      <span class="demo-tui__topbar-tab">Settings</span>
      <span class="demo-tui__topbar-tab">Dashboard</span>
      <span class="demo-tui__topbar-tab demo-tui__topbar-tab--active">Cart (1 op)</span>
      <span class="demo-tui__topbar-online"><span class="demo-tui__topbar-dot t-emerald" aria-hidden="true">&#x25CF;</span> online</span>
    </span>
  </header>

  <div class="demo-tui__panels">
    <section class="demo-tui__panel demo-tui__panel--main" aria-label="transfer form">
      <header class="demo-tui__panel-title">
        <span class="demo-tui__tab demo-tui__tab--active">transfer</span>
        <span class="demo-tui__tab">pending transfers</span>
      </header>
      <div class="demo-tui__panel-body">
        <div class="demo-tui__field">
          <span class="demo-tui__label demo-tui__label--req"><span class="demo-tui__asterisk">*</span> From</span>
          <span class="demo-tui__input">alice</span>
        </div>
        <div class="demo-tui__field">
          <span class="demo-tui__label demo-tui__label--req"><span class="demo-tui__asterisk">*</span> To</span>
          <span class="demo-tui__input demo-tui__input--empty"></span>
          <span class="demo-tui__field-hint t-accent">known account</span>
        </div>
        <div class="demo-tui__field demo-tui__field--amount">
          <span class="demo-tui__label demo-tui__label--req"><span class="demo-tui__asterisk">*</span> Amount</span>
          <span class="demo-tui__input demo-tui__input--placeholder">Amount e.g.: 1.123</span>
          <span class="demo-tui__amount-asset">HIVE</span>
          <span class="demo-tui__amount-all">All!</span>
        </div>
        <div class="demo-tui__field">
          <span class="demo-tui__label">&nbsp; Memo</span>
          <span class="demo-tui__input demo-tui__input--placeholder">Memo e.g.: For the coffee!</span>
        </div>
        <div class="demo-tui__actions">
          <span class="demo-tui__btn demo-tui__btn--primary">Add to cart (a)</span>
          <span class="demo-tui__btn demo-tui__btn--primary">Finalize transaction (f)</span>
        </div>
      </div>
    </section>

    <aside class="demo-tui__right-panel" aria-label="account info">
      <div class="demo-tui__right-panel-body">
        <p class="demo-tui__stat"><span class="t-dim">RC:</span> 100.00 %</p>
        <p class="demo-tui__stat"><span class="t-dim">HIVE balance:</span> 100000.000</p>
        <p class="demo-tui__stat"><span class="t-dim">HBD balance:</span> 100000.000</p>
        <hr class="demo-tui__sep" />
        <p class="demo-tui__cart-title t-amber">1 OPERATION IN THE CART</p>
        <div class="demo-tui__cart-item">
          <span class="t-dim">1.</span> <span class="t-emerald">transfer</span>
          <span class="t-dim">25.000 HIVE &rarr; bob</span>
        </div>
      </div>
    </aside>
  </div>

  <footer class="demo-tui__bottombar">
    <span><span class="demo-tui__key">esc</span> <span class="t-dim">Back</span></span>
    <span><span class="demo-tui__key">^d</span> <span class="t-dim">Dashboard</span></span>
    <span><span class="demo-tui__key">^l</span> <span class="t-dim">Lock wallet</span></span>
    <span><span class="demo-tui__key">^s</span> <span class="t-dim">Settings</span></span>
    <span><span class="demo-tui__key">^t</span> <span class="t-dim">Transaction summary</span></span>
    <span><span class="demo-tui__key">^p</span> <span class="t-dim">palette</span></span>
  </footer>
</div>`;

/* ------------------------------------------------------------------ *
 * CLI visualization — same transfer scenario in CLI mode              *
 * Shows process transfer with JSON-style output                       *
 * ------------------------------------------------------------------ */
const demoCliHtml = `<span class="t-dim">clive@cli:~/.clive/mapped_host_directory$</span> clive process transfer-to-account \\
  <span class="t-cyan">--from</span> alice <span class="t-cyan">--to</span> bob \\
  <span class="t-cyan">--amount</span> <span class="t-yellow">"25.000 HIVE"</span> \\
  <span class="t-cyan">--memo</span> <span class="t-yellow">"payment for services"</span>

<span class="t-dim">  Using beekeeper at</span> <span class="t-cyan">http://127.0.0.1:39507</span>
<span class="t-subtle">  Loading profile...</span>

<span class="t-dim">  ┌─────────────────────────────────────────────┐</span>
<span class="t-dim">  │</span>  <span class="t-yellow">Transaction summary</span>                       <span class="t-dim">│</span>
<span class="t-dim">  ├────────────┬────────────────────────────────┤</span>
<span class="t-dim">  │</span> <span class="t-cyan">From</span>       <span class="t-dim">│</span>  <span class="t-emerald">alice</span>                         <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">To</span>         <span class="t-dim">│</span>  <span class="t-accent">bob</span>                           <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">Amount</span>     <span class="t-dim">│</span>  25.000 HIVE                    <span class="t-dim">│</span>
<span class="t-dim">  │</span> <span class="t-cyan">Memo</span>       <span class="t-dim">│</span>  payment for services           <span class="t-dim">│</span>
<span class="t-dim">  └────────────┴────────────────────────────────┘</span>

  Broadcast? [<span class="t-emerald">Y</span>/n]: <span class="t-emerald">Y</span>

<span class="t-emerald">  Transaction was successfully broadcast.</span>
<span class="t-dim">  Block:</span> 82,451,307  <span class="t-dim">TxID:</span> <span class="t-subtle">a3f9e1...c704</span>

<span class="t-dim">clive@cli:~/.clive/mapped_host_directory$</span> <span class="t-cursor" aria-hidden="true">▌</span>`;
---

<TuiPanel title="$ clive --tui" id="demo" class="demo reveal-scroll">
  <div class="container-x">
    <header class="demo__header reveal">
      <p class="demo__eyebrow"><span aria-hidden="true">// </span>see it in action</p>
      <h2 id="demo-heading" class="demo__title">
        <span class="section-title__prefix" aria-hidden="true">## </span>demo
      </h2>
      <p class="demo__lead">A typical session: unlock the wallet, sign a transfer, broadcast.</p>
    </header>

    <div class="demo__frame reveal">
      <TerminalFrame title="clive — transfer" ariaLabel="Clive TUI/CLI demo preview" as="div">
        <WorkflowTabs
          client:visible
          panelId="demo"
          tuiHtml={demoTuiHtml}
          cliHtml={demoCliHtml}
        />
      </TerminalFrame>
    </div>
  </div>
</TuiPanel>

<style>
  :global(.demo) {
    padding: var(--space-3);
    min-height: calc(100dvh - var(--header-h));
  }

  .demo__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .demo__eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    color: var(--color-primary-bright);
    text-transform: lowercase;
  }

  .demo__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-mono-display);
    line-height: var(--leading-mono-display);
    text-transform: lowercase;
    margin: 0 0 var(--space-3);
  }

  .section-title__prefix {
    color: var(--color-text-subtle);
  }

  .demo__lead {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .demo__frame {
    max-width: 60rem;
    margin-inline: auto;
  }

  /* ============================================================
   * White-space overrides for WorkflowTabs panels
   * TUI content = normal flow, CLI content = pre-wrapped
   * ============================================================ */
  :global(.demo__frame .workflow-tabs__panel) {
    white-space: normal;
  }

  :global(.demo__frame [id$="-panel-cli"].workflow-tabs__panel) {
    white-space: pre-wrap;
  }

  /* ============================================================
   * TUI panels — CSS borders replacing unicode box-drawing.
   * Lives inside innerHTML, so all selectors must be :global().
   * ============================================================ */
  :global(.demo-tui) {
    white-space: normal;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--mode-text, var(--color-text));
    font-feature-settings:
      "calt" 0,
      "liga" 0;
    font-variant-ligatures: none;
    font-variant-numeric: tabular-nums;
    background-color: var(--mode-bg, transparent);
    border-radius: var(--radius-md);
    transition: background-color 300ms ease, color 300ms ease;
  }

  /* ============================================================
   * Top bar — real Clive header: user/status + tabs + online
   * ============================================================ */
  :global(.demo-tui__topbar) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    font-size: var(--text-xs);
    transition: background-color 300ms ease, border-color 300ms ease;
  }
  :global(.demo-tui__topbar-left),
  :global(.demo-tui__topbar-right) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  :global(.demo-tui__topbar-user) {
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }
  :global(.demo-tui__topbar-unlock) {
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    font-size: 0.9em;
  }
  :global(.demo-tui__topbar-tab) {
    padding: 0.125rem 0.5rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    border-radius: var(--radius-xs);
  }
  :global(.demo-tui__topbar-tab--active) {
    background-color: rgba(96, 165, 250, 0.20);
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }
  :global(.demo-tui__topbar-online) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    font-size: 0.9em;
  }
  :global(.demo-tui__topbar-dot) {
    font-size: 0.5em;
  }

  /* ============================================================
   * Main panels — form (70%) + right info panel (30%)
   * ============================================================ */
  :global(.demo-tui__panels) {
    display: grid;
    grid-template-columns: 1fr 12rem;
    gap: 0;
  }

  @media (max-width: 40rem) {
    :global(.demo-tui__panels) {
      grid-template-columns: 1fr;
    }
  }

  :global(.demo-tui__panel) {
    border: 1px solid var(--mode-border, var(--color-border-default));
    background: transparent;
    display: flex;
    flex-direction: column;
    min-height: 14rem;
    transition: border-color 300ms ease;
  }
  :global(.demo-tui__panel--main) {
    border-right: none;
  }
  @media (max-width: 40rem) {
    :global(.demo-tui__panel--main) {
      border-right: 1px solid var(--mode-border, var(--color-border-default));
    }
  }

  /* Panel title bar with operation tabs */
  :global(.demo-tui__panel-title) {
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    color: var(--mode-text-muted, var(--color-text-muted));
    border-bottom: 1px solid var(--mode-border, var(--color-border-default));
    letter-spacing: 0.02em;
    display: flex;
    gap: var(--space-1);
    transition: border-color 300ms ease;
  }
  :global(.demo-tui__tab) {
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-xs);
    color: var(--mode-text-muted, var(--color-text-muted));
  }
  :global(.demo-tui__tab--active) {
    background-color: rgba(96, 165, 250, 0.20);
    color: var(--mode-text, var(--color-text));
    font-weight: var(--font-weight-medium);
  }

  :global(.demo-tui__panel-body) {
    flex: 1;
    padding: var(--space-3) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.demo-tui__panel-body > p) {
    margin: 0;
  }

  /* ============================================================
   * Right panel — RC, balances, cart
   * ============================================================ */
  :global(.demo-tui__right-panel) {
    border: 1px solid var(--mode-border, var(--color-border-default));
    background: transparent;
    display: flex;
    flex-direction: column;
    transition: border-color 300ms ease;
  }
  :global(.demo-tui__right-panel-body) {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-xs);
  }
  :global(.demo-tui__stat) {
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
  :global(.demo-tui__cart-title) {
    margin: 0;
    font-weight: var(--font-weight-semibold);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
  }
  :global(.demo-tui__cart-item) {
    font-size: var(--text-xs);
    padding-left: var(--space-1);
  }

  :global(.demo-tui__sep) {
    border: none;
    border-top: 1px solid var(--mode-border, var(--color-border-default));
    margin: var(--space-2) 0;
    width: 100%;
    transition: border-color 300ms ease;
  }

  /* ============================================================
   * Transfer form fields — green-bordered inputs
   * ============================================================ */
  :global(.demo-tui__field) {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  :global(.demo-tui__field--amount) {
    flex-wrap: nowrap;
  }

  :global(.demo-tui__label) {
    min-width: 4rem;
    text-align: right;
    flex-shrink: 0;
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--mode-text-muted, var(--color-text-muted));
  }
  :global(.demo-tui__label--req) {
    color: #22c55e;
  }
  :global(.demo-tui__asterisk) {
    color: #22c55e;
    font-weight: var(--font-weight-bold);
  }

  :global(.demo-tui__input) {
    flex: 1;
    padding: var(--space-1) var(--space-2);
    border: 1px solid #22c55e;
    border-radius: var(--radius-xs);
    font-size: var(--text-sm);
    color: var(--mode-text, var(--color-text));
    min-width: 0;
    transition: border-color 300ms ease;
  }
  :global(.demo-tui__input--placeholder) {
    color: var(--mode-text-subtle, rgba(255, 255, 255, 0.38));
    font-style: italic;
  }
  :global(.demo-tui__input--empty) {
    min-height: 1.5em;
  }
  :global(.demo-tui__field-hint) {
    font-size: 0.6875rem;
    flex-basis: 100%;
    padding-left: calc(4rem + var(--space-2));
    margin-top: -0.25rem;
  }

  /* Amount row extras */
  :global(.demo-tui__amount-asset) {
    font-size: var(--text-xs);
    color: var(--mode-text-muted, var(--color-text-muted));
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--mode-border, var(--color-border-default));
    border-radius: var(--radius-xs);
    flex-shrink: 0;
    white-space: nowrap;
  }
  :global(.demo-tui__amount-all) {
    font-size: var(--text-xs);
    color: #4ade80;
    font-weight: var(--font-weight-semibold);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ============================================================
   * Action buttons — solid green background
   * ============================================================ */
  :global(.demo-tui__actions) {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-top: var(--space-3);
    flex-wrap: wrap;
  }

  :global(.demo-tui__btn) {
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    font-size: var(--text-xs);
  }
  :global(.demo-tui__btn--primary) {
    background-color: #22c55e;
    color: #fff;
    padding: 0.15em 0.6em;
    border-radius: 2px;
  }

  /* ============================================================
   * Bottom bar — keyboard shortcuts (real Clive format)
   * ============================================================ */
  :global(.demo-tui__bottombar) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-1) var(--space-3);
    background-color: var(--mode-bg-header, var(--color-bg-elevated));
    border-top: 1px solid var(--mode-border, var(--color-border-default));
    font-size: 0.6875rem;
    color: var(--mode-text-muted, var(--color-text-muted));
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: background-color 300ms ease, border-color 300ms ease;
  }

  /* Keyboard shortcut key styling — amber accent */
  :global(.demo-tui__key) {
    color: var(--color-accent-warning, #f59e0b);
    font-weight: var(--font-weight-semibold);
    font-size: 0.9em;
    margin-right: 0.125rem;
  }

  /* ============================================================
   * Responsive — hide right panel details on narrow screens
   * ============================================================ */
  @media (max-width: 25rem) {
    :global(.demo-tui__topbar-right .demo-tui__topbar-tab:nth-child(-n+2)) {
      display: none;
    }
  }
</style>
