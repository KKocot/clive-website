---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/ui/PostCard.astro";
import TerminalFrame from "../../components/ui/TerminalFrame.astro";
import Button from "../../components/ui/Button.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const emptyTerminalHtml = [
  `<span class="t-prompt">$</span> clive blog list`,
  `  <span class="t-muted">No posts yet. The first one is being written.</span>`,
  `  <span class="t-muted">Subscribe to RSS to know when it lands.</span>`,
].join("\n");
---

<BaseLayout
  title="Blog — Clive"
  description="Updates, deep-dives, and how-tos from the Clive project."
>
  <section class="blog-index" aria-labelledby="blog-index-heading">
    <div class="container-x blog-index__inner">
      <header class="blog-index__header">
        <div class="blog-index__heading-row">
          <div>
            <h1 id="blog-index-heading" class="h-display blog-index__title">
              Blog
            </h1>
            <p class="blog-index__subhead">
              Updates, deep-dives, and how-tos from the Clive project.
            </p>
          </div>

          <a
            class="blog-index__rss"
            href="/rss.xml"
            aria-label="Subscribe via RSS"
            title="RSS feed"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 11a9 9 0 0 1 9 9"></path>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <circle cx="5" cy="19" r="1"></circle>
            </svg>
            <span>RSS</span>
          </a>
        </div>
      </header>

      {
        allPosts.length === 0 ? (
          <div class="blog-index__empty">
            <TerminalFrame
              title="clive — blog"
              ariaLabel="Empty state terminal"
            >
              <Fragment set:html={emptyTerminalHtml} />
            </TerminalFrame>
            <div class="blog-index__empty-cta">
              <Button variant="secondary" href="/rss.xml">
                Subscribe via RSS
                <span slot="icon-end" aria-hidden="true">→</span>
              </Button>
            </div>
          </div>
        ) : (
          <ul class="blog-index__grid" role="list">
            {allPosts.map((post) => (
              <li>
                <PostCard post={post} />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-index {
    padding-block: var(--space-16) var(--space-24);
  }

  @media (min-width: 48rem) {
    .blog-index {
      padding-block: var(--space-20) var(--space-32);
    }
  }

  .blog-index__heading-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .blog-index__title {
    font-size: var(--text-5xl);
    margin: 0 0 var(--space-3) 0;
    color: var(--color-text);
  }

  @media (min-width: 48rem) {
    .blog-index__title {
      font-size: var(--text-6xl);
    }
  }

  .blog-index__subhead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
    margin: 0;
  }

  .blog-index__rss {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    background-color: transparent;
    transition:
      color var(--duration-fast) var(--ease-out-quad),
      background-color var(--duration-fast) var(--ease-out-quad),
      border-color var(--duration-fast) var(--ease-out-quad);
  }

  .blog-index__rss:hover {
    color: var(--color-accent-warning);
    border-color: var(--color-border-strong);
    background-color: var(--color-bg-overlay);
  }

  .blog-index__header {
    margin-bottom: var(--space-12);
  }

  @media (min-width: 48rem) {
    .blog-index__header {
      margin-bottom: var(--space-16);
    }
  }

  .blog-index__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 48rem) {
    .blog-index__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .blog-index__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-index__empty {
    margin-top: var(--space-8);
    padding-block: var(--space-10) var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    max-width: 40rem;
    margin-inline: auto;
  }

  .blog-index__empty :global(.terminal) {
    width: 100%;
  }

  .blog-index__empty :global(.t-prompt) {
    color: var(--color-accent-primary);
  }

  .blog-index__empty :global(.t-muted) {
    color: var(--color-text-muted);
  }

  .blog-index__empty-cta {
    display: flex;
    justify-content: center;
  }
</style>
