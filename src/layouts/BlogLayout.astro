---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={`${title} — Clive Blog`} description={description}>
  <article>
    {heroImage && <img src={heroImage} alt={title} />}
    <h1>{title}</h1>
    {
      pubDate && (
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      )
    }
    {
      updatedDate && (
        <p>
          Updated:{" "}
          <time datetime={updatedDate.toISOString()}>
            {updatedDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        </p>
      )
    }
    <slot />
  </article>
</BaseLayout>
