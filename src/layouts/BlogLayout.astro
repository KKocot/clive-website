---
import BaseLayout from "./BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  /** Pre-rendered MDX content body — used to estimate reading time */
  rawBody?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  rawBody,
} = Astro.props;

const baseProps = {
  title: `${title} — Clive Blog`,
  ...(description !== undefined ? { description } : {}),
  ogType: "article" as const,
  ...(pubDate !== undefined ? { pubDate } : {}),
  ...(updatedDate !== undefined ? { modDate: updatedDate } : {}),
  ...(tags !== undefined ? { tags } : {}),
  ...(heroImage !== undefined ? { image: heroImage } : {}),
};

const formatDate = (date: Date): string =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "2-digit",
    year: "numeric",
  });

// Reading time estimate from raw body (200 wpm)
const wordsPerMinute = 200;
const wordCount = rawBody !== undefined && rawBody.trim().length > 0
  ? rawBody.trim().split(/\s+/).length
  : 0;
const readingTimeMinutes = wordCount > 0 ? Math.max(1, Math.round(wordCount / wordsPerMinute)) : 0;
const readingTimeLabel = readingTimeMinutes > 0 ? `${readingTimeMinutes} min read` : null;

const showUpdated =
  updatedDate !== undefined &&
  pubDate !== undefined &&
  updatedDate.getTime() !== pubDate.getTime();

const headingId = "blog-post-heading";
---

<BaseLayout {...baseProps}>
  <article class="blog-article" aria-labelledby={headingId}>
    <header class="blog-article__header container-x">
      {
        tags && tags.length > 0 && (
          <ul class="blog-article__tags" aria-label="Tags">
            {tags.map((tag) => (
              <li>
                <Badge variant="neutral">{tag}</Badge>
              </li>
            ))}
          </ul>
        )
      }

      <h1 id={headingId} class="blog-article__title">{title}</h1>

      {
        description && (
          <p class="blog-article__description">{description}</p>
        )
      }

      <div class="blog-article__meta">
        {
          pubDate && (
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          )
        }
        {
          readingTimeLabel && (
            <>
              <span aria-hidden="true" class="blog-article__meta-sep">·</span>
              <span>{readingTimeLabel}</span>
            </>
          )
        }
        {
          showUpdated && updatedDate && (
            <>
              <span aria-hidden="true" class="blog-article__meta-sep">·</span>
              <span>
                Updated{" "}
                <time datetime={updatedDate.toISOString()}>
                  {formatDate(updatedDate)}
                </time>
              </span>
            </>
          )
        }
      </div>

      {
        heroImage && (
          <figure class="blog-article__hero">
            <img src={heroImage} alt={title} loading="eager" decoding="async" />
          </figure>
        )
      }
    </header>

    <div class="blog-article__body container-x">
      <div class="prose-clive">
        <slot />
      </div>

      <footer class="blog-article__footer">
        <hr class="blog-article__divider" />
        <a href="/blog" class="blog-article__back">
          <span aria-hidden="true">←</span>
          <span>Back to blog</span>
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding-block: var(--space-16) var(--space-20);
  }

  @media (min-width: 48rem) {
    .blog-article {
      padding-block: var(--space-20) var(--space-24);
    }
  }

  .blog-article__header {
    max-width: 45rem; /* 720px */
    margin-inline: auto;
  }

  .blog-article__tags {
    list-style: none;
    margin: 0 0 var(--space-6) 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .blog-article__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-4) 0;
    max-width: 45rem;
  }

  @media (min-width: 48rem) {
    .blog-article__title {
      font-size: var(--text-5xl);
    }
  }

  .blog-article__description {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-6) 0;
    max-width: 45rem;
  }

  .blog-article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-10);
  }

  .blog-article__meta-sep {
    color: var(--color-border-strong);
  }

  .blog-article__hero {
    margin: var(--space-10) 0 0 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
  }

  .blog-article__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-article__body {
    max-width: 45rem; /* 720px */
    margin-inline: auto;
    margin-top: var(--space-12);
  }

  .blog-article__footer {
    margin-top: var(--space-16);
  }

  .blog-article__divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 0 0 var(--space-8) 0;
  }

  .blog-article__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-subtle);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    margin-inline-start: calc(-1 * var(--space-3));
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease-out-quad), background-color var(--duration-fast) var(--ease-out-quad);
  }

  .blog-article__back:hover {
    color: var(--color-text);
    background-color: var(--color-bg-overlay);
  }

  /* ============================================================
   * PROSE — MDX article styling
   * Scoped to .prose-clive so it only affects blog post body
   * ============================================================ */
  .prose-clive {
    font-size: var(--text-lg);
    line-height: var(--leading-prose);
    color: var(--color-text-muted);
  }

  .prose-clive :global(p) {
    line-height: var(--leading-prose);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4) 0;
  }

  .prose-clive :global(h2) {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: var(--space-12) 0 var(--space-4) 0;
    scroll-margin-top: 6rem;
  }

  .prose-clive :global(h3) {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: var(--space-8) 0 var(--space-3) 0;
    scroll-margin-top: 6rem;
  }

  .prose-clive :global(h4) {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin: var(--space-6) 0 var(--space-2) 0;
  }

  .prose-clive :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: color var(--duration-fast) var(--ease-out-quad);
  }

  .prose-clive :global(a:hover) {
    color: var(--color-accent-primary-hover);
  }

  .prose-clive :global(strong) {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }

  .prose-clive :global(em) {
    font-style: italic;
  }

  .prose-clive :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-text);
    background-color: var(--color-bg-elevated);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .prose-clive :global(pre) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin: var(--space-6) 0;
    overflow-x: auto;
  }

  .prose-clive :global(pre code) {
    font-family: inherit;
    font-size: inherit;
    background: transparent;
    padding: 0;
    border: 0;
    color: inherit;
  }

  .prose-clive :global(blockquote) {
    border-left: 4px solid var(--color-accent-primary);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .prose-clive :global(blockquote p) {
    margin-bottom: var(--space-2);
  }

  .prose-clive :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose-clive :global(ul) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-4) 0;
    list-style: disc;
  }

  .prose-clive :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-4) 0;
    list-style: decimal;
  }

  .prose-clive :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-prose);
  }

  .prose-clive :global(li::marker) {
    color: var(--color-text-subtle);
  }

  .prose-clive :global(li > ul),
  .prose-clive :global(li > ol) {
    margin: var(--space-2) 0;
  }

  .prose-clive :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: var(--space-12) 0;
  }

  .prose-clive :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-8) 0;
    border: 1px solid var(--color-border);
  }

  .prose-clive :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-size: var(--text-sm);
  }

  .prose-clive :global(th),
  .prose-clive :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
  }

  .prose-clive :global(th) {
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }
</style>
