---
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import "@hiveio/honeycomb-solid/base.css";
import SEO from "../components/seo/SEO.astro";
import Footer from "../components/sections/Footer.astro";
import { LINKS } from "../config/links";
import NavbarModeSwitch from "../components/islands/NavbarModeSwitch.tsx";

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideFooter?: boolean;
  /** Hide the page from indexing (e.g. drafts, preview). */
  noindex?: boolean;
}

const {
  title,
  description = "Clive — power-user wallet for Hive. Encrypted keys, mouse-driven TUI, blockchain operations from your terminal.",
  image,
  hideFooter = false,
  noindex,
} = Astro.props;

const centerNavLinks: {
  href: string;
  label: string;
  external?: boolean;
}[] = [
  { href: "/#features", label: "features" },
  { href: "/#install", label: "install" },
  { href: "/#preview", label: "preview" },
  { href: "/#blog", label: "blog" },
];

const gitlabLink = {
  href: LINKS.GITLAB,
  label: "GitLab",
  external: true as const,
};

const currentPath = Astro.url.pathname;

const isHomePage = currentPath === "/" || currentPath === "/index.html";

const isCurrent = (href: string): boolean => {
  if (href.startsWith("#") || href.includes("#")) return false;
  if (/^https?:\/\//.test(href)) return false;
  if (href === "/") return !isHomePage;
  return currentPath === href || currentPath.startsWith(href + "/");
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      {...image ? { ogImage: image } : {}}
      {...noindex ? { noindex } : {}}
      jsonLdWebsite={
        Astro.url.pathname === "/" || Astro.url.pathname === "/index.html"
      }
    />
    <slot name="head" />
  </head>
  <body class="tui-scanlines min-h-dvh">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="tmux-bar sticky top-0 z-50 w-full">
      <div class="tmux-bar__inner container-x flex items-center justify-between">
        <!-- Left: home tab + nav tabs -->
        <div class="tmux-bar__tabs flex items-center">
          <a
            href="/"
            class="tmux-tab tmux-tab--home"
            aria-label="Clive — home"
            {...(isCurrent("/") ? { "aria-current": "page" } : {})}
          >
            <span class="tmux-tab__index">0:</span>clive
          </a>

          <nav
            class="hidden items-center md:flex"
            aria-label="Primary navigation"
          >
            {
              centerNavLinks.map((link, i) => {
                const current = isCurrent(link.href);
                return (
                  <a
                    href={link.href}
                    class="tmux-tab"
                    {...(current ? { "aria-current": "page" } : {})}
                    {...(link.external
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    <span class="tmux-tab__index">{i + 1}:</span>
                    {link.label}
                    {link.external && (
                      <span aria-hidden="true" class="ml-0.5 text-xs">
                        {"↗"}
                      </span>
                    )}
                  </a>
                );
              })
            }
          </nav>
        </div>

        <!-- Right: mode switch + GitLab link + mobile hamburger -->
        <div class="flex items-center">
          <div class="hidden md:flex items-center">
            <NavbarModeSwitch client:load />
          </div>
          <a
            href={gitlabLink.href}
            class="tmux-tab tmux-tab--gitlab hidden md:flex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={gitlabLink.label}
          >
            <svg
              viewBox="0 0 24 24"
              width="14"
              height="14"
              fill="currentColor"
              aria-hidden="true"
              class="tmux-tab__gitlab-icon"
            >
              <path d="m23.6004 9.5927-.0337-.0862L20.3.9814a.851.851 0 0 0-.3362-.405.8748.8748 0 0 0-.9997.0539.8748.8748 0 0 0-.29.4399l-2.2055 6.748H7.5375l-2.2057-6.748a.8573.8573 0 0 0-.29-.4412.8748.8748 0 0 0-.9997-.0537.8585.8585 0 0 0-.3362.4049L.4332 9.5015l-.0325.0862a6.0657 6.0657 0 0 0 2.0119 7.0105l.0113.0087.03.0213 4.976 3.7264 2.462 1.8633 1.4995 1.1321a1.0085 1.0085 0 0 0 1.2197 0l1.4997-1.1321 2.4619-1.8633 5.006-3.7489.0125-.01a6.0682 6.0682 0 0 0 2.0094-7.003z" />
            </svg>
            GitLab
          </a>

          <details class="md:hidden">
            <summary
              class="tmux-tab tmux-tab--hamburger flex cursor-pointer items-center justify-center"
              aria-label="Toggle menu"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="4" y1="7" x2="20" y2="7"></line>
                <line x1="4" y1="12" x2="20" y2="12"></line>
                <line x1="4" y1="17" x2="20" y2="17"></line>
              </svg>
            </summary>
            <div class="tmux-mobile-dropdown absolute inset-x-0 border-b p-3">
              <div class="mb-2 flex items-center justify-center">
                <NavbarModeSwitch client:load />
              </div>
              <nav aria-label="Mobile navigation">
                <ul class="flex flex-col gap-0.5">
                  {
                    centerNavLinks.map((link, i) => {
                      const current = isCurrent(link.href);
                      return (
                        <li>
                          <a
                            href={link.href}
                            class="tmux-tab tmux-tab--mobile"
                            {...(current ? { "aria-current": "page" } : {})}
                            {...(link.external
                              ? {
                                  target: "_blank",
                                  rel: "noopener noreferrer",
                                }
                              : {})}
                          >
                            <span class="tmux-tab__index">{i + 1}:</span>
                            {link.label}
                            {link.external && (
                              <span aria-hidden="true" class="ml-1 text-xs">
                                {"↗"}
                              </span>
                            )}
                          </a>
                        </li>
                      );
                    })
                  }
                  <li>
                    <a
                      href={gitlabLink.href}
                      class="tmux-tab tmux-tab--mobile flex items-center gap-1.5"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <span class="tmux-tab__index"
                        >{centerNavLinks.length + 1}:</span
                      >
                      <svg
                        viewBox="0 0 24 24"
                        width="14"
                        height="14"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="m23.6004 9.5927-.0337-.0862L20.3.9814a.851.851 0 0 0-.3362-.405.8748.8748 0 0 0-.9997.0539.8748.8748 0 0 0-.29.4399l-2.2055 6.748H7.5375l-2.2057-6.748a.8573.8573 0 0 0-.29-.4412.8748.8748 0 0 0-.9997-.0537.8585.8585 0 0 0-.3362.4049L.4332 9.5015l-.0325.0862a6.0657 6.0657 0 0 0 2.0119 7.0105l.0113.0087.03.0213 4.976 3.7264 2.462 1.8633 1.4995 1.1321a1.0085 1.0085 0 0 0 1.2197 0l1.4997-1.1321 2.4619-1.8633 5.006-3.7489.0125-.01a6.0682 6.0682 0 0 0 2.0094-7.003z" />
                      </svg>
                      gitlab
                      <span aria-hidden="true" class="text-xs">{"↗"}</span>
                    </a>
                  </li>
                </ul>
              </nav>
            </div>
          </details>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {!hideFooter && <Footer />}

    <script>
      // Close <details> mobile menu when a link inside is clicked or Escape pressed.
      // Astro hashes/bundles this script so it runs once per page navigation.
      const closeOpenMenus = () => {
        document
          .querySelectorAll<HTMLDetailsElement>("header details[open]")
          .forEach((d) => d.removeAttribute("open"));
      };
      document
        .querySelectorAll<HTMLAnchorElement>("header details a")
        .forEach((a) => {
          a.addEventListener("click", () => {
            a.closest("details")?.removeAttribute("open");
          });
        });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeOpenMenus();
      });
    </script>

    <script>
      // Scroll-triggered reveal — IntersectionObserver for .reveal-scroll elements.
      // Elements get .reveal-scroll--visible once 15% visible, then unobserved.
      const initRevealObserver = () => {
        const elements = document.querySelectorAll('.reveal-scroll');
        if (!elements.length) return;

        const prefersReducedMotion = window.matchMedia(
          '(prefers-reduced-motion: reduce)',
        ).matches;

        if (prefersReducedMotion) {
          elements.forEach((el) => el.classList.add('reveal-scroll--visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('reveal-scroll--visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 },
        );

        elements.forEach((el) => observer.observe(el));
      };

      initRevealObserver();

      // Active section indicator — IntersectionObserver for hash nav links.
      // Highlights the matching nav tab when a section scrolls into the
      // upper 20-60% of the viewport (the "under navbar" sweet spot).
      const initSectionObserver = () => {
        const sectionIds = ['hero', 'features', 'install', 'preview', 'blog'];
        const sections = sectionIds
          .map((id) => document.getElementById(id))
          .filter((el): el is HTMLElement => el !== null);

        if (!sections.length) return;

        const homeLinks = document.querySelectorAll<HTMLAnchorElement>('a.tmux-tab--home');
        const hashLinks = document.querySelectorAll<HTMLAnchorElement>(
          'a.tmux-tab[href*="#"], a.tmux-tab--mobile[href*="#"]',
        );
        const allNavLinks = [...homeLinks, ...hashLinks];

        const clearActive = () => {
          allNavLinks.forEach((link) => link.removeAttribute('aria-current'));
        };

        const setActive = (sectionId: string) => {
          allNavLinks.forEach((link) => {
            if (sectionId === 'hero') {
              if (link.classList.contains('tmux-tab--home')) {
                link.setAttribute('aria-current', 'true');
              } else {
                link.removeAttribute('aria-current');
              }
              return;
            }
            const hash = new URL(link.href, location.origin).hash.replace('#', '');
            if (hash === sectionId) {
              link.setAttribute('aria-current', 'true');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        // Track which sections are currently intersecting.
        const visibleSections = new Map<string, IntersectionObserverEntry>();

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const id = entry.target.id;
              if (entry.isIntersecting) {
                visibleSections.set(id, entry);
              } else {
                visibleSections.delete(id);
              }
            });

            if (visibleSections.size === 0) {
              clearActive();
              return;
            }

            // Pick the section closest to the top of the viewport.
            let topSection: string | null = null;
            let topY = Infinity;
            visibleSections.forEach((entry, id) => {
              const rect = entry.target.getBoundingClientRect();
              if (rect.top < topY) {
                topY = rect.top;
                topSection = id;
              }
            });

            if (topSection) setActive(topSection);
          },
          {
            // Trigger when section is in the top 20-60% band of the viewport.
            rootMargin: '-20% 0px -60% 0px',
          },
        );

        sections.forEach((section) => observer.observe(section));
      };

      initSectionObserver();
    </script>

    <style>
      /* ============================================================
       * TMUX TAB BAR — status line style navigation
       * ============================================================ */
      .tmux-bar {
        background-color: var(--color-bg-surface);
        border-bottom: 1px solid var(--tui-panel-border-color);
        font-family: var(--font-mono);
        transition:
          background-color var(--mode-transition, 300ms) ease,
          border-color var(--mode-transition, 300ms) ease;
      }

      .tmux-bar__inner {
        height: 2.5rem; /* 40px — compact like tmux status bar */
      }

      /* --- Individual tab --- */
      .tmux-tab {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
        padding: 0.25rem 0.625rem; /* 4px 10px */
        font-size: var(--text-sm);
        font-weight: var(--font-weight-medium);
        line-height: 1;
        color: var(--color-text-muted);
        text-decoration: none;
        white-space: nowrap;
        border-radius: var(--radius-xs);
        transition:
          color var(--duration-fast) var(--ease-out),
          background-color var(--duration-fast) var(--ease-out);
      }

      .tmux-tab:hover,
      .tmux-tab:focus-visible {
        color: var(--color-text);
        background-color: var(--color-bg-overlay);
        text-shadow: var(--glow-intensity) var(--glow-color);
      }

      .tmux-tab[aria-current="page"],
      .tmux-tab[aria-current="true"] {
        color: var(--color-bg);
        background-color: var(--color-primary);
        transition:
          background-color var(--mode-transition, 300ms) ease,
          color var(--mode-transition, 300ms) ease;
      }

      .tmux-tab[aria-current="page"] .tmux-tab__index,
      .tmux-tab[aria-current="true"] .tmux-tab__index {
        color: var(--color-bg);
        opacity: 0.7;
      }

      /* --- Tab index prefix (the "0:", "1:" etc.) --- */
      .tmux-tab__index {
        color: var(--color-text-subtle);
        font-variant-numeric: tabular-nums;
      }

      /* --- Home tab --- */
      .tmux-tab--home {
        font-weight: var(--font-weight-semibold);
        color: var(--color-primary-bright);
      }

      .tmux-tab--home:hover,
      .tmux-tab--home:focus-visible {
        color: var(--color-primary-soft);
        background-color: var(--color-bg-overlay);
      }

      .tmux-tab--home .tmux-tab__index {
        color: var(--color-primary);
        opacity: 0.6;
      }

      .tmux-tab--home[aria-current="page"] {
        color: var(--color-bg);
        background-color: var(--color-primary);
      }

      .tmux-tab--home[aria-current="page"] .tmux-tab__index {
        color: var(--color-bg);
        opacity: 0.7;
      }

      /* --- GitLab tab (right side) --- */
      .tmux-tab--gitlab {
        gap: 0.375rem;
      }

      .tmux-tab__gitlab-icon {
        flex-shrink: 0;
      }

      /* --- Hamburger tab (mobile) --- */
      .tmux-tab--hamburger {
        width: 2.5rem;
        height: 100%;
        padding: 0;
        justify-content: center;
        list-style: none; /* remove details marker */
      }

      .tmux-tab--hamburger::-webkit-details-marker {
        display: none;
      }

      /* --- Mobile dropdown --- */
      .tmux-mobile-dropdown {
        background-color: var(--color-bg-surface);
        border-color: var(--tui-panel-border-color);
        font-family: var(--font-mono);
        /* Position below the bar (height = 2.5rem = 40px) */
        top: 2.5rem;
        transition:
          background-color var(--mode-transition, 300ms) ease,
          border-color var(--mode-transition, 300ms) ease;
      }

      /* --- Mobile tab variant --- */
      .tmux-tab--mobile {
        display: flex;
        width: 100%;
        padding: 0.5rem 0.75rem;
        font-size: var(--text-sm);
        border-radius: var(--radius-xs);
      }

      .tmux-tab--mobile:hover,
      .tmux-tab--mobile:focus-visible {
        color: var(--color-text);
        background-color: var(--color-bg-overlay);
      }

      .tmux-tab--mobile[aria-current="page"],
      .tmux-tab--mobile[aria-current="true"] {
        color: var(--color-bg);
        background-color: var(--color-primary);
      }

      .tmux-tab--mobile[aria-current="page"] .tmux-tab__index,
      .tmux-tab--mobile[aria-current="true"] .tmux-tab__index {
        color: var(--color-bg);
        opacity: 0.7;
      }

      /* --- Mode switch (TUI/CLI segmented control) --- */
      :global(.mode-switch) {
        position: relative;
        display: inline-flex;
        align-items: center;
        margin-right: 0.5rem;
        padding: 2px;
        background-color: var(--color-bg);
        border: 1px solid var(--tui-panel-border-color);
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
      }

      :global(.mode-switch__indicator) {
        position: absolute;
        top: 2px;
        left: 2px;
        width: calc(50% - 2px);
        height: calc(100% - 4px);
        background-color: var(--color-primary);
        border-radius: calc(var(--radius-sm) - 2px);
        transition: transform var(--duration-normal) var(--ease-out);
        pointer-events: none;
      }

      :global(.mode-switch__btn) {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.25rem 0.75rem;
        font-size: var(--text-xs);
        font-weight: var(--font-weight-semibold);
        line-height: 1;
        letter-spacing: 0.05em;
        color: var(--color-text-subtle);
        background: transparent;
        border: none;
        border-radius: calc(var(--radius-sm) - 2px);
        cursor: pointer;
        white-space: nowrap;
        transition: color var(--duration-fast) var(--ease-out);
      }

      :global(.mode-switch__btn:hover) {
        color: var(--color-text);
      }

      :global(.mode-switch__btn--active) {
        color: var(--color-bg);
      }

      :global(.mode-switch__btn--active:hover) {
        color: var(--color-bg);
      }

      /* --- Reduced motion --- */
      @media (prefers-reduced-motion: reduce) {
        .tmux-tab,
        :global(.mode-switch__btn),
        :global(.mode-switch__indicator) {
          transition: none;
        }
      }
    </style>
  </body>
</html>
