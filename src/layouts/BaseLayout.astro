---
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import "@hiveio/honeycomb-solid/base.css";
import SEO from "../components/seo/SEO.astro";
import Footer from "../components/sections/Footer.astro";
import { LINKS } from "../config/links";

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideFooter?: boolean;
  /** Hide the page from indexing (e.g. drafts, preview). */
  noindex?: boolean;
}

const {
  title,
  description = "Clive — power-user wallet for Hive. Encrypted keys, mouse-driven TUI, full blockchain operations from your terminal.",
  image,
  hideFooter = false,
  noindex,
} = Astro.props;

const centerNavLinks: {
  href: string;
  label: string;
  external?: boolean;
}[] = [
  { href: "/#features", label: "Features" },
  { href: "/#install", label: "Install" },
  { href: "/#demo", label: "Demo" },
];

const gitlabLink = {
  href: LINKS.GITLAB,
  label: "GitLab",
  external: true as const,
};

const currentPath = Astro.url.pathname;

const isCurrent = (href: string): boolean => {
  // Hash-only or page-with-hash links never count as current page.
  if (href.startsWith("#") || href.includes("#")) return false;
  // External links never count.
  if (/^https?:\/\//.test(href)) return false;
  if (href === "/") {
    return currentPath === "/" || currentPath === "/index.html";
  }
  return currentPath === href || currentPath.startsWith(href + "/");
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      {...image ? { ogImage: image } : {}}
      {...noindex ? { noindex } : {}}
      jsonLdWebsite={
        Astro.url.pathname === "/" || Astro.url.pathname === "/index.html"
      }
    />
    <slot name="head" />
  </head>
  <body class="min-h-dvh">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header
      class="sticky top-0 z-50 w-full border-b backdrop-blur-md"
      style="background-color: rgba(26, 32, 48, 0.85); border-color: var(--color-border-subtle);"
    >
      <div
        class="container-x flex h-16 items-center justify-between gap-4 md:grid md:grid-cols-3"
      >
        <a
          href="/"
          class="flex items-center gap-2 font-mono text-base font-semibold tracking-tight md:justify-self-start"
          aria-label="Clive — home"
        >
          <span style="color: var(--color-primary-bright)">$</span>
          <span style="color: var(--color-text)">clive</span>
        </a>

        <nav
          class="hidden items-center gap-1 md:flex md:justify-self-center"
          aria-label="Primary navigation"
        >
          {
            centerNavLinks.map((link) => {
              const current = isCurrent(link.href);
              return (
                <a
                  href={link.href}
                  class="nav-link rounded-md px-3 py-2 text-sm font-medium transition-colors"
                  {...(current ? { "aria-current": "page" } : {})}
                  {...(link.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  {link.label}
                  {link.external && (
                    <span aria-hidden="true" class="ml-0.5 text-xs">
                      {"↗"}
                    </span>
                  )}
                </a>
              );
            })
          }
        </nav>

        <a
          href={gitlabLink.href}
          class="nav-link nav-link-icon hidden h-10 w-10 items-center justify-center rounded-md text-sm font-medium transition-colors md:flex md:justify-self-end"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={gitlabLink.label}
        >
          <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="m23.6004 9.5927-.0337-.0862L20.3.9814a.851.851 0 0 0-.3362-.405.8748.8748 0 0 0-.9997.0539.8748.8748 0 0 0-.29.4399l-2.2055 6.748H7.5375l-2.2057-6.748a.8573.8573 0 0 0-.29-.4412.8748.8748 0 0 0-.9997-.0537.8585.8585 0 0 0-.3362.4049L.4332 9.5015l-.0325.0862a6.0657 6.0657 0 0 0 2.0119 7.0105l.0113.0087.03.0213 4.976 3.7264 2.462 1.8633 1.4995 1.1321a1.0085 1.0085 0 0 0 1.2197 0l1.4997-1.1321 2.4619-1.8633 5.006-3.7489.0125-.01a6.0682 6.0682 0 0 0 2.0094-7.003z" />
          </svg>
        </a>

        <details class="md:hidden">
          <summary
            class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-md"
            style="color: var(--color-text);"
            aria-label="Toggle menu"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="4" y1="7" x2="20" y2="7"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="17" x2="20" y2="17"></line>
            </svg>
          </summary>
          <div
            class="absolute inset-x-0 top-16 border-b p-4"
            style="background-color: var(--color-bg-elevated); border-color: var(--color-border-subtle);"
          >
            <nav aria-label="Mobile navigation">
              <ul class="flex flex-col gap-1">
                {
                  centerNavLinks.map((link) => {
                    const current = isCurrent(link.href);
                    return (
                      <li>
                        <a
                          href={link.href}
                          class="nav-link-mobile block rounded-md px-3 py-3 text-base font-medium"
                          {...(current ? { "aria-current": "page" } : {})}
                          {...(link.external
                            ? { target: "_blank", rel: "noopener noreferrer" }
                            : {})}
                        >
                          {link.label}
                          {link.external && (
                            <span aria-hidden="true" class="ml-1 text-xs">
                              {"↗"}
                            </span>
                          )}
                        </a>
                      </li>
                    );
                  })
                }
                <li>
                  <a
                    href={gitlabLink.href}
                    class="nav-link-mobile flex items-center gap-2 rounded-md px-3 py-3 text-base font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      width="20"
                      height="20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="m23.6004 9.5927-.0337-.0862L20.3.9814a.851.851 0 0 0-.3362-.405.8748.8748 0 0 0-.9997.0539.8748.8748 0 0 0-.29.4399l-2.2055 6.748H7.5375l-2.2057-6.748a.8573.8573 0 0 0-.29-.4412.8748.8748 0 0 0-.9997-.0537.8585.8585 0 0 0-.3362.4049L.4332 9.5015l-.0325.0862a6.0657 6.0657 0 0 0 2.0119 7.0105l.0113.0087.03.0213 4.976 3.7264 2.462 1.8633 1.4995 1.1321a1.0085 1.0085 0 0 0 1.2197 0l1.4997-1.1321 2.4619-1.8633 5.006-3.7489.0125-.01a6.0682 6.0682 0 0 0 2.0094-7.003z" />
                    </svg>
                    {gitlabLink.label}
                    <span aria-hidden="true" class="ml-1 text-xs">{"↗"}</span>
                  </a>
                </li>
              </ul>
            </nav>
          </div>
        </details>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {!hideFooter && <Footer />}

    <script>
      // Close <details> mobile menu when a link inside is clicked or Escape pressed.
      // Astro hashes/bundles this script so it runs once per page navigation.
      const closeOpenMenus = () => {
        document
          .querySelectorAll<HTMLDetailsElement>("header details[open]")
          .forEach((d) => d.removeAttribute("open"));
      };
      document
        .querySelectorAll<HTMLAnchorElement>("header details a")
        .forEach((a) => {
          a.addEventListener("click", () => {
            a.closest("details")?.removeAttribute("open");
          });
        });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeOpenMenus();
      });
    </script>

    <style>
      .nav-link {
        color: var(--color-text-muted);
        transition:
          color var(--duration-fast) var(--ease-out),
          background-color var(--duration-fast) var(--ease-out);
      }
      .nav-link:hover,
      .nav-link:focus-visible {
        color: var(--color-primary-bright);
        background-color: var(--color-bg-overlay);
      }
      .nav-link[aria-current="page"] {
        color: var(--color-primary-bright);
      }

      .nav-link-mobile {
        color: var(--color-text);
        transition: background-color var(--duration-fast) var(--ease-out);
      }
      .nav-link-mobile:hover,
      .nav-link-mobile:focus-visible {
        background-color: var(--color-bg-overlay);
      }
      .nav-link-mobile[aria-current="page"] {
        color: var(--color-primary-bright);
      }
    </style>
  </body>
</html>
